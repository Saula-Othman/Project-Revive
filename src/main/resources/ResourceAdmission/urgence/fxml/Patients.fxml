<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pro.revive.controllers.ControllersAdmission.PatientController"
      styleClass="page-container" spacing="20">
    <padding><Insets top="28" bottom="28" left="28" right="28"/></padding>

    <!-- Header row -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="3">
            <Label text="Patients" styleClass="page-title"/>
            <Label text="Gestion du fichier patients" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouveau Patient" onAction="#handleAdd" styleClass="btn-primary" prefHeight="38"/>
    </HBox>

    <!-- Search bar -->
    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="card">
        <padding><Insets top="14" bottom="14" left="16" right="16"/></padding>
        <Label text="🔍" style="-fx-font-size: 16px;"/>
        <TextField fx:id="searchField" promptText="Rechercher par nom, prénom, CIN, N° Sécurité Sociale..."
                   HBox.hgrow="ALWAYS" styleClass="search-field" onKeyReleased="#handleSearch"/>
        <Button text="Effacer" onAction="#handleClearSearch" styleClass="btn-ghost"/>
    </HBox>

    <!-- Table -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="0">
        <padding><Insets top="0" bottom="0" left="0" right="0"/></padding>
        <TableView fx:id="patientTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <!-- colId masquée - les IDs ne s'affichent pas en UI -->
                <TableColumn fx:id="colId" text="ID" prefWidth="0" visible="false"/>
                <TableColumn fx:id="colNom" text="Nom" prefWidth="130"/>
                <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="130"/>
                <TableColumn fx:id="colDN" text="Date Naiss." prefWidth="110"/>
                <TableColumn fx:id="colSexe" text="Sexe" prefWidth="60"/>
                <TableColumn fx:id="colGS" text="Gr. Sanguin" prefWidth="90"/>
                <TableColumn fx:id="colTel" text="Téléphone" prefWidth="130"/>
                <TableColumn fx:id="colCin" text="CIN" prefWidth="100"/>
                <TableColumn fx:id="colAdmissions" text="Admissions" prefWidth="90"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="220"/>
            </columns>
        </TableView>
    </VBox>

    <!-- Status bar -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="12">
        <Label fx:id="statusLabel" text="Chargement..." styleClass="status-text"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel" text="" styleClass="status-count"/>
    </HBox>

    <!-- Toast container (overlay) -->
    <fx:define>
        <fx:reference source="this"/>
    </fx:define>
</VBox>

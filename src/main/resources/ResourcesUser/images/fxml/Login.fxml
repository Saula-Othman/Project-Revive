<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Fix 1: hospital photo covers full right panel (StackPane full size) -->
<!-- Fix 2: gif removed from header -->
<!-- Fix 4: Google button moved below login form -->
<!-- Fix 5: S'inscrire as a proper styled button box -->

<HBox prefHeight="750.0" prefWidth="1100.0"
      stylesheets="@../css/user.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pro.revive.controllers.ControllersUser.LoginController">

   <!-- ═══ LEFT PANEL — Form ═══ -->
   <ScrollPane fitToWidth="true" prefWidth="580" minWidth="520"
               style="-fx-background-color: #ffffff; -fx-background: #ffffff; -fx-border-width: 0;">
      <content>
         <VBox alignment="TOP_CENTER" prefWidth="580"
               style="-fx-background-color: #ffffff; -fx-padding: 32px 60px 32px 60px; -fx-spacing: 0;">

            <!-- Logo -->
            <ImageView fitWidth="140" fitHeight="62" preserveRatio="true" style="-fx-padding: 0 0 8px 0;">
               <image><Image url="@../images/logo_revive.png"/></image>
            </ImageView>

            <!-- Welcome -->
            <VBox spacing="3" style="-fx-padding: 10px 0 18px 0;">
               <Label text="Bienvenue !" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A1D23;" />
               <Label text="Connectez-vous a votre espace de gestion" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
            </VBox>

            <!-- Identifiant -->
            <VBox spacing="4" style="-fx-padding: 0 0 10px 0;">
               <Label text="Identifiant" styleClass="label" />
               <TextField fx:id="tfIdentifiant" promptText="Ex: ADXXX001" styleClass="text-input" />
            </VBox>

            <!-- Mot de passe -->
            <VBox spacing="4" style="-fx-padding: 0 0 10px 0;">
               <Label text="Mot de passe" styleClass="label" />
               <PasswordField fx:id="pfMotDePasse" promptText="••••••••" styleClass="text-input" />
            </VBox>

            <!-- CAPTCHA -->
            <VBox spacing="4" style="-fx-padding: 0 0 10px 0;">
               <Label text="Code de verification" styleClass="label" />
               <HBox spacing="8" alignment="CENTER_LEFT">
                  <Canvas fx:id="captchaCanvas" width="185" height="46"
                          style="-fx-border-color: #E5E7EB; -fx-border-radius: 8px;" />
                  <Button text="🔄" onAction="#refreshCaptcha" mnemonicParsing="false"
                          style="-fx-background-color: #EEF2FF; -fx-text-fill: #0B4EA2;
                                 -fx-background-radius: 8px; -fx-padding: 7px 11px;
                                 -fx-font-size: 13px; -fx-cursor: hand;
                                 -fx-border-color: #BFDBFE; -fx-border-radius: 8px; -fx-border-width: 1px;" />
               </HBox>
               <TextField fx:id="tfCaptcha" promptText="Saisir le code ci-dessus" styleClass="text-input" />
            </VBox>

            <!-- Error -->
            <Label fx:id="lblError" text="" styleClass="error-label"
                   visible="false" managed="false" style="-fx-padding: 0 0 6px 0;" />

            <!-- Login button -->
            <Button text="Connexion →" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleLogin"
                    style="-fx-background-color: #0B4EA2; -fx-text-fill: #ffffff;
                           -fx-background-radius: 10px; -fx-padding: 12px;
                           -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" />

            <!-- Forgot password link -->
            <Button text="J'ai oublie mon mot de passe" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleForgotPassword"
                    style="-fx-background-color: transparent; -fx-text-fill: #0B4EA2;
                           -fx-border-width: 0; -fx-font-size: 12px; -fx-cursor: hand;
                           -fx-underline: true; -fx-padding: 6px 0 10px 0;" />

            <!-- Separator -->
            <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 10px 0;">
               <Region HBox.hgrow="ALWAYS"
                       style="-fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0; -fx-pref-height: 1px;" />
               <Label text="ou" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px;" />
               <Region HBox.hgrow="ALWAYS"
                       style="-fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0; -fx-pref-height: 1px;" />
            </HBox>

            <!-- Fix 4: Google button BELOW login form -->
            <Button text="🔵  Se connecter avec Google" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleGoogleLogin"
                    style="-fx-background-color: #ffffff; -fx-text-fill: #374151;
                           -fx-border-color: #E5E7EB; -fx-border-width: 1.5px;
                           -fx-border-radius: 10px; -fx-background-radius: 10px;
                           -fx-padding: 10px; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-cursor: hand;" />

            <!-- Fix 5: S'inscrire as a proper styled box button -->
            <Button text="➕  Creer un compte" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleSignUp"
                    style="-fx-background-color: #D1FAE5; -fx-text-fill: #065F46;
                           -fx-border-color: #6EE7B7; -fx-border-width: 1.5px;
                           -fx-border-radius: 10px; -fx-background-radius: 10px;
                           -fx-padding: 10px; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-margin: 8px 0 0 0;" />

         </VBox>
      </content>
   </ScrollPane>

   <!-- ═══ RIGHT PANEL — Decorative ═══ -->
   <StackPane fx:id="rightPanel" HBox.hgrow="ALWAYS" styleClass="login-right-panel"
              style="-fx-background-image: url('../images/hospital.png');
                     -fx-background-size: 150% auto;
                     -fx-background-position: center center;
                     -fx-background-repeat: no-repeat;">

      <!-- Light overlay for text readability -->
      <StackPane style="-fx-background-color: rgba(11,78,162,0.45);" />

      <!-- Content over photo -->
      <VBox alignment="CENTER" spacing="18" style="-fx-padding: 40px;">

         <ImageView fitWidth="220" fitHeight="96" preserveRatio="true">
            <image><Image url="@../images/logo_revive.png"/></image>
         </ImageView>

         <VBox alignment="CENTER" spacing="6">
            <Label text="REVIVE"
                   style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
            <Label text="Systeme de Gestion des Urgences Medicales"
                   style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.85);
                          -fx-alignment: center;" wrapText="true" />
         </VBox>

         <VBox spacing="12" alignment="CENTER" style="-fx-padding: 16px 0 0 0;">
            <HBox spacing="10" alignment="CENTER">
               <Label text="✅" style="-fx-font-size: 14px;" />
               <Label text="Gestion complete du personnel hospitalier"
                      style="-fx-text-fill: #ffffff; -fx-font-size: 13px;" />
            </HBox>
            <HBox spacing="10" alignment="CENTER">
               <Label text="✅" style="-fx-font-size: 14px;" />
               <Label text="Authentification securisee multi-roles"
                      style="-fx-text-fill: #ffffff; -fx-font-size: 13px;" />
            </HBox>
            <HBox spacing="10" alignment="CENTER">
               <Label text="✅" style="-fx-font-size: 14px;" />
               <Label text="Notifications email automatiques"
                      style="-fx-text-fill: #ffffff; -fx-font-size: 13px;" />
            </HBox>
         </VBox>

      </VBox>
   </StackPane>

</HBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
    prefHeight="750.0" prefWidth="1100.0"
    stylesheets="@../css/user.css"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="pro.revive.controllers.ControllersUser.ForgotPasswordController"
    style="-fx-background-color: #F0F4F8;">

   <VBox alignment="CENTER" maxWidth="440.0"
         style="-fx-background-color: #ffffff; -fx-background-radius: 20px;
                -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 24, 0, 0, 6);">

      <!-- Header -->
      <VBox alignment="CENTER" spacing="6"
            style="-fx-background-color: #1A56DB; -fx-background-radius: 20px 20px 0 0; -fx-padding: 28px 40px 24px;">
         <Label text="REVIVE" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" />
         <Label text="Mot de passe oublie" style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;" />
      </VBox>

      <!-- Form -->
      <VBox spacing="18" style="-fx-padding: 32px 36px 36px;">
         <VBox spacing="4">
            <Label text="Recuperer votre mot de passe"
                   style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1A1D23;" />
            <Label text="Entrez votre adresse email pour recevoir un code de reinitialisation."
                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" wrapText="true" />
         </VBox>

         <VBox spacing="6">
            <Label text="Adresse email" styleClass="label" />
            <TextField fx:id="tfEmail" promptText="exemple@email.com" styleClass="text-input" />
         </VBox>

         <Label fx:id="lblError" text="" styleClass="error-label" visible="false" managed="false" />
         <Label fx:id="lblSuccess" text="" style="-fx-text-fill: #10B981; -fx-font-size: 12px; -fx-font-weight: bold;"
                visible="false" managed="false" />

         <Button text="📧 Envoyer le code" maxWidth="Infinity"
                 styleClass="btn, btn-primary" style="-fx-padding: 12px; -fx-font-size: 14px;"
                 onAction="#handleSendCode" mnemonicParsing="false" />

         <Button text="← Retour a la connexion" maxWidth="Infinity"
                 styleClass="btn, btn-secondary" style="-fx-padding: 10px;"
                 onAction="#goBack" mnemonicParsing="false" />
      </VBox>
   </VBox>
</StackPane>

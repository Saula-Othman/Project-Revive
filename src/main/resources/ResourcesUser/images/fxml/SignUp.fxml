<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="750.0" prefWidth="1100.0" stylesheets="@../css/user.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pro.revive.controllers.ControllersUser.SignUpController">

   <!-- LEFT: Form -->
   <ScrollPane fitToWidth="true" prefWidth="520" minWidth="460"
               style="-fx-background-color: #ffffff; -fx-background: #ffffff; -fx-border-width: 0;">
      <content>
         <VBox alignment="TOP_CENTER" prefWidth="520"
               style="-fx-background-color: #ffffff; -fx-padding: 32px 44px; -fx-spacing: 0;">

            <!-- Logo -->
            <ImageView fitWidth="130" fitHeight="58" preserveRatio="true" style="-fx-padding: 0 0 6px 0;">
               <image><Image url="@../images/logo_revive.png"/></image>
            </ImageView>

            <VBox spacing="3" style="-fx-padding: 10px 0 20px 0;">
               <Label text="Creer un compte" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1A1D23;" />
               <Label text="Remplissez le formulaire — votre compte sera active par un administrateur"
                      style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" wrapText="true" />
            </VBox>

            <!-- Nom + Prenom -->
            <HBox spacing="12" style="-fx-padding: 0 0 12px 0;">
               <VBox styleClass="field-group" HBox.hgrow="ALWAYS">
                  <Label styleClass="label" text="Nom *" />
                  <TextField fx:id="tfNom" promptText="Nom de famille" styleClass="text-input" />
               </VBox>
               <VBox styleClass="field-group" HBox.hgrow="ALWAYS">
                  <Label styleClass="label" text="Prenom *" />
                  <TextField fx:id="tfPrenom" promptText="Prenom" styleClass="text-input" />
               </VBox>
            </HBox>

            <!-- Role -->
            <VBox styleClass="field-group" style="-fx-padding: 0 0 12px 0;">
               <Label styleClass="label" text="Role *" />
               <ComboBox fx:id="cbRole" promptText="Selectionner votre role..." maxWidth="Infinity" />
            </VBox>

            <!-- Date naissance -->
            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 12px 0;">
               <VBox styleClass="field-group" HBox.hgrow="ALWAYS">
                  <Label styleClass="label" text="Date de naissance *" />
                  <DatePicker fx:id="dpDateNaissance" maxWidth="Infinity" />
                  <Label fx:id="lblAgeError" text="" visible="false" managed="false"
                         style="-fx-font-size: 11px; -fx-text-fill: #EF4444; -fx-font-weight: bold;" />
               </VBox>
               <VBox styleClass="field-group" alignment="CENTER_LEFT">
                  <Label styleClass="label" text="Age" />
                  <Label fx:id="lblAge" text="—"
                         style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0B4EA2; -fx-padding: 6px 0 0 0;" />
               </VBox>
            </HBox>

            <!-- Telephone -->
            <VBox styleClass="field-group" style="-fx-padding: 0 0 12px 0;">
               <Label styleClass="label" text="Telephone *" />
               <HBox spacing="8">
                  <ComboBox fx:id="cbPays" prefWidth="200" />
                  <TextField fx:id="tfTelephone" promptText="Ex: 55 123 456" styleClass="text-input" HBox.hgrow="ALWAYS" />
               </HBox>
            </VBox>

            <!-- Email -->
            <VBox styleClass="field-group" style="-fx-padding: 0 0 16px 0;">
               <Label styleClass="label" text="Email *" />
               <TextField fx:id="tfEmail" promptText="exemple@email.com" styleClass="text-input" />
               <Label fx:id="lblEmailStatus" text="" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
            </VBox>

            <!-- Info box -->
            <VBox style="-fx-background-color: #EFF6FF; -fx-border-color: #BFDBFE; -fx-border-width: 1.5px;
                         -fx-border-radius: 10px; -fx-background-radius: 10px;
                         -fx-padding: 12px 14px 12px 14px; -fx-spacing: 4px; -fx-margin: 0 0 16px 0;">
               <Label text="ℹ️ Votre mot de passe sera genere automatiquement et envoye par email apres validation."
                      style="-fx-font-size: 11px; -fx-text-fill: #1E40AF;" wrapText="true" />
            </VBox>

            <!-- Error / Success -->
            <Label fx:id="lblError" text="" styleClass="error-label" visible="false" managed="false"
                   style="-fx-padding: 0 0 8px 0;" />
            <Label fx:id="lblSuccess" text="" visible="false" managed="false"
                   style="-fx-text-fill: #059669; -fx-font-size: 12px; -fx-font-weight: bold;
                          -fx-padding: 0 0 10px 0;" wrapText="true" />

            <!-- Buttons -->
            <VBox spacing="8">
               <Button text="✔ Soumettre ma demande" maxWidth="Infinity"
                       mnemonicParsing="false" onAction="#handleSignUp"
                       style="-fx-background-color: #0B4EA2; -fx-text-fill: #ffffff;
                              -fx-background-radius: 10px; -fx-padding: 12px;
                              -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" />
               <Button text="← Retour a la connexion" maxWidth="Infinity"
                       mnemonicParsing="false" onAction="#goBack"
                       style="-fx-background-color: #EAF6FF; -fx-text-fill: #0B4EA2;
                              -fx-border-color: #BFDBFE; -fx-border-width: 1.5px;
                              -fx-border-radius: 10px; -fx-background-radius: 10px;
                              -fx-padding: 10px; -fx-font-size: 13px; -fx-cursor: hand;" />
            </VBox>

         </VBox>
      </content>
   </ScrollPane>

   <!-- RIGHT: Decorative -->
   <StackPane HBox.hgrow="ALWAYS" style="-fx-background-color: #EEF6FF;">
      <ImageView fitWidth="700" fitHeight="750" preserveRatio="false" opacity="0.85">
         <image><Image url="@../images/hospital.png"/></image>
      </ImageView>
      <StackPane style="-fx-background-color: rgba(11,78,162,0.15);" />
      <VBox alignment="BOTTOM_CENTER" style="-fx-padding: 0 0 40px 0;">
         <Label text="REVIVE" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #ffffff;
                                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),8,0,0,2);" />
         <Label text="Systeme de Gestion des Urgences"
                style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.90);
                       -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),6,0,0,1);" />
      </VBox>
   </StackPane>

</HBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" stylesheets="@../css/user.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pro.revive.controllers.ControllersUser.M6PersonnelDeleteController">

   <!-- ── SIDEBAR ── -->
   <left>
      <VBox styleClass="sidebar" BorderPane.alignment="CENTER">
         <VBox styleClass="logo-wrap">
            <ImageView fitWidth="170.0" preserveRatio="true" pickOnBounds="true">
               <image><Image url="@../logo_revive.png" /></image>
            </ImageView>
            <Label styleClass="logo-sub" text="Gestion du Personnel" />
         </VBox>
         <Label styleClass="nav-section" text="MENU" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="🏠  Tableau de Bord" onAction="#goDashboard" />
         <Button mnemonicParsing="false" styleClass="nav-item, active" text="👥  Personnel" onAction="#goPersonnel" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="📩  Inscriptions" onAction="#goInscriptions" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="📋  Historique" onAction="#goHistorique" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="🕐  Shifts" onAction="#goShifts" />
         <Region VBox.vgrow="ALWAYS" />
         <VBox styleClass="sidebar-card">
            <Label styleClass="sc-title" text="SUPPRESSION" />
            <Label styleClass="sc-alert" text="Action irreversible !" />
            <Button mnemonicParsing="false" styleClass="sc-btn" text="Deconnexion" onAction="#deconnexion" />
         </VBox>
      </VBox>
   </left>

   <!-- ── MAIN: centered dialog ── -->
   <center>
      <VBox alignment="CENTER" style="-fx-background-color: #EEF4FB;" BorderPane.alignment="CENTER">
         <VBox alignment="CENTER" styleClass="dialog"
               style="-fx-background-color: #fff; -fx-background-radius: 20px; -fx-padding: 40px; -fx-max-width: 500px;">
            <Label style="-fx-font-size: 52px; -fx-padding: 0 0 14px 0;" text="🗑️" />
            <Label style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #1A1D23; -fx-padding: 0 0 8px 0;"
                   text="Confirmer la Suppression" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-padding: 0 0 20px 0; -fx-alignment: center;"
                   text="Vous etes sur le point de supprimer definitivement cet employe.&#10;Cette action ne peut pas etre annulee."
                   textAlignment="CENTER" wrapText="true" />

            <!-- Staff Info -->
            <VBox style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-width: 1.5px;
                         -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 14px;">
               <VBox.margin><Insets bottom="20.0" /></VBox.margin>
               <HBox style="-fx-padding: 0 0 8px 0;" alignment="CENTER">
                  <Label style="-fx-font-size: 13px; -fx-text-fill: #6B7280;" text="Nom complet" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblNomPrenom" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #1A1D23;" text="—" />
               </HBox>
               <HBox style="-fx-padding: 0 0 8px 0;" alignment="CENTER">
                  <Label style="-fx-font-size: 13px; -fx-text-fill: #6B7280;" text="Identifiant" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblIdentifiant" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #1E40AF;" text="—" />
               </HBox>
               <HBox alignment="CENTER">
                  <Label style="-fx-font-size: 13px; -fx-text-fill: #6B7280;" text="Role" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblRole" styleClass="badge, badge-xx" style="-fx-font-size: 10px;" text="—" />
               </HBox>
            </VBox>

            <!-- Warning -->
            <VBox style="-fx-background-color: #FEF2F2; -fx-border-color: #EF4444; -fx-border-width: 0 0 0 4px;
                         -fx-border-radius: 0; -fx-padding: 12px 16px;">
               <VBox.margin><Insets bottom="20.0" /></VBox.margin>
               <Label style="-fx-font-size: 12px; -fx-text-fill: #991B1B;"
                      text="⚠  Attention : La suppression de cet employe va retirer son acces au systeme et supprimer son profil definitivement. Cette operation est irreversible."
                      wrapText="true" />
            </VBox>

            <!-- Buttons -->
            <HBox spacing="12.0">
               <Button mnemonicParsing="false" styleClass="btn, btn-secondary" style="-fx-padding: 12px;"
                       text="❌  Annuler" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#cancel" />
               <Button mnemonicParsing="false" styleClass="btn, btn-danger" style="-fx-padding: 12px;"
                       text="🗑  Oui, Supprimer" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#confirmDelete" />
            </HBox>
         </VBox>
      </VBox>
   </center>

</BorderPane>

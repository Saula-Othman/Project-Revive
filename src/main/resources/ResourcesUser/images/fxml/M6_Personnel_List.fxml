<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" stylesheets="@../css/user.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pro.revive.controllers.ControllersUser.M6PersonnelListController">

   <!-- ── SIDEBAR ── -->
   <left>
      <VBox styleClass="sidebar" BorderPane.alignment="CENTER">
         <VBox styleClass="logo-wrap">
            <ImageView fitWidth="170.0" preserveRatio="true" pickOnBounds="true">
               <image><Image url="@../logo_revive.png" /></image>
            </ImageView>
            <Label styleClass="logo-sub" text="Gestion du Personnel" />
         </VBox>
         <Label styleClass="nav-section" text="MENU" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="🏠  Tableau de Bord" onAction="#goDashboard" />
         <Button mnemonicParsing="false" styleClass="nav-item, active" text="👥  Personnel" onAction="#goPersonnel" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="📩  Inscriptions" onAction="#goInscriptions" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="📋  Historique" onAction="#goHistorique" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="🕐  Shifts" onAction="#goShifts" />
         <Region VBox.vgrow="ALWAYS" />
         <VBox styleClass="sidebar-card">
            <Label styleClass="sc-title" text="MODULE ACTIF" />
            <Label styleClass="sc-alert" text="Gestion Personnel" />
            <Button mnemonicParsing="false" styleClass="sc-btn" text="Deconnexion" onAction="#deconnexion" />
         </VBox>
      </VBox>
   </left>

   <!-- ── MAIN ── -->
   <center>
      <VBox styleClass="main" BorderPane.alignment="CENTER">

         <!-- Topbar -->
         <HBox styleClass="topbar">
            <VBox spacing="2">
               <Label styleClass="page-title" text="Gestion du Personnel" />
               <Label fx:id="lblSubtitle" styleClass="page-sub" text="0 employes enregistres" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" styleClass="btn-refresh" text="➕  Nouveau" onAction="#goAdd" />
            <HBox styleClass="user-chip">
               <VBox alignment="CENTER_RIGHT" styleClass="user-info">
                  <Label fx:id="lblUserName" styleClass="user-name" text="..." />
                  <Label fx:id="lblUserRole" styleClass="user-role" text="Administrateur" />
               </VBox>
               <Label styleClass="user-av" text="A" />
            </HBox>
         </HBox>
         <Region styleClass="topbar-stripe" />

         <!-- Selection toolbar -->
         <HBox spacing="12" alignment="CENTER_LEFT"
               style="-fx-background-color: #ffffff; -fx-padding: 10px 28px;
                      -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
            <CheckBox fx:id="cbSelectAll" text="Tout selectionner" onAction="#handleSelectAll"
                      style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #334155;" />
            <Label fx:id="lblSelectionCount" text=""
                   style="-fx-font-size: 12px; -fx-text-fill: #0B4EA2; -fx-font-weight: bold;"
                   visible="false" managed="false" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnDeleteSelected" text="🗑  Supprimer la selection"
                    mnemonicParsing="false" onAction="#deleteSelected"
                    visible="false" managed="false"
                    styleClass="btn, btn-danger" style="-fx-font-size: 12px; -fx-padding: 7px 16px;" />
         </HBox>

         <!-- Filters row 1 -->
         <HBox styleClass="filters" spacing="10.0" alignment="CENTER_LEFT">
            <Button fx:id="btnFilterTous" mnemonicParsing="false" styleClass="filter-btn, active" text="Tous" onAction="#filterTous" />
            <Button fx:id="btnFilterMedecin" mnemonicParsing="false" styleClass="filter-btn" text="Medecin Urgentiste" onAction="#filterMedecin" />
            <Button fx:id="btnFilterInfirmier" mnemonicParsing="false" styleClass="filter-btn" text="Infirmier Triage" onAction="#filterInfirmier" />
            <Button fx:id="btnFilterAgent" mnemonicParsing="false" styleClass="filter-btn" text="Agent Accueil" onAction="#filterAgent" />
            <Button fx:id="btnFilterBiologiste" mnemonicParsing="false" styleClass="filter-btn" text="Biologiste Radiologue" onAction="#filterBiologiste" />
            <Button fx:id="btnFilterLogistique" mnemonicParsing="false" styleClass="filter-btn" text="Resp. Logistique" onAction="#filterLogistique" />
            <Button fx:id="btnFilterAdmin" mnemonicParsing="false" styleClass="filter-btn" text="Administrateur" onAction="#filterAdmin" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT"
                  style="-fx-max-width: 280px; -fx-background-color: #fff; -fx-border-color: #CBD5E1;
                         -fx-border-width: 1.5px; -fx-background-radius: 20px; -fx-border-radius: 20px;">
               <Label style="-fx-padding: 0 0 0 12px; -fx-text-fill: #9CA3AF;" text="🔍" />
               <TextField fx:id="tfSearch" promptText="Rechercher..."
                          style="-fx-background-color: transparent; -fx-border-width: 0;"
                          HBox.hgrow="ALWAYS" />
            </HBox>
         </HBox>

         <!-- Staff list -->
         <ScrollPane fitToWidth="true" styleClass="scroll" VBox.vgrow="ALWAYS">
            <content>
               <VBox fx:id="vbStaffList" spacing="10.0" style="-fx-padding: 16px 28px 24px 28px;" />
            </content>
         </ScrollPane>

      </VBox>
   </center>

</BorderPane>

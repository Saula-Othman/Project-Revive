<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" stylesheets="@../css/user.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pro.revive.controllers.ControllersUser.ShiftsController">

   <top>
      <VBox>
         <StackPane prefHeight="88" style="-fx-background-color: linear-gradient(to right, #0B4EA2, #0E9B8A);">
            <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: transparent;">
               <HBox styleClass="header-logo-zone" alignment="CENTER" spacing="8">
                  <ImageView fitWidth="150" fitHeight="65" preserveRatio="true">
                     <image><Image url="@../images/logo_revive.png"/></image>
                  </ImageView>
               </HBox>
               <Region style="-fx-background-color: rgba(255,255,255,0.30); -fx-min-width: 1px; -fx-pref-width: 1px; -fx-min-height: 88px;" />
               <VBox styleClass="header-title-zone" spacing="2">
                  <Label styleClass="header-module-label" text="Gestion du Personnel" />
                  <Label styleClass="header-page-title" text="Emploi du Temps" />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               <HBox alignment="CENTER" style="-fx-padding: 0 16 0 0;" spacing="8">
                  <HBox styleClass="user-chip">
                     <VBox alignment="CENTER_RIGHT" styleClass="user-info">
                        <Label fx:id="lblUserName" styleClass="user-name" text="Admin" />
                        <Label fx:id="lblUserRole" styleClass="user-role" text="Administrateur" />
                     </VBox>
                     <Label styleClass="user-av" text="👤" />
                  </HBox>
               </HBox>
            </HBox>
         </StackPane>
         <Region styleClass="header-strip" />
      </VBox>
   </top>

   <left>
      <VBox styleClass="sidebar" BorderPane.alignment="CENTER">
         <Label styleClass="nav-section" text="NAVIGATION" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="▣  Tableau de Bord" onAction="#goDashboard" maxWidth="Infinity" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="👥  Gestion Personnel" onAction="#goPersonnel" maxWidth="Infinity" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="📋  Historique" onAction="#goHistorique" maxWidth="Infinity" />
         <Button mnemonicParsing="false" styleClass="nav-item, active" text="🕐  Emploi du Temps" maxWidth="Infinity" />
         <Region VBox.vgrow="ALWAYS" />
         <VBox styleClass="sidebar-card">
            <Label styleClass="sc-title" text="Emploi du Temps" />
            <Label styleClass="sc-alert" text="Planning hebdomadaire" />
            <Button mnemonicParsing="false" styleClass="sc-btn" text="Deconnexion" onAction="#deconnexion" />
         </VBox>
      </VBox>
   </left>

   <center>
      <VBox styleClass="main" BorderPane.alignment="CENTER" spacing="14">

         <!-- Add shift form -->
         <VBox styleClass="card" spacing="10">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0B4EA2; -fx-padding: 0 0 4px 0;"
                   text="📅 Assigner un Shift Hebdomadaire" />
            <Label text="Choisissez un lundi — le shift sera applique du lundi au dimanche pour cet agent."
                   style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" wrapText="true" />
            <HBox spacing="12" alignment="CENTER_LEFT">
               <VBox styleClass="field-group" prefWidth="200">
                  <Label styleClass="label" text="Semaine (Lundi) *" />
                  <DatePicker fx:id="dpWeekStart" maxWidth="Infinity" />
               </VBox>
               <VBox styleClass="field-group" HBox.hgrow="ALWAYS">
                  <Label styleClass="label" text="Agent *" />
                  <ComboBox fx:id="cbAgent" maxWidth="Infinity" />
               </VBox>
               <VBox styleClass="field-group" prefWidth="200">
                  <Label styleClass="label" text="Type de Shift *" />
                  <ComboBox fx:id="cbTypeShift" maxWidth="Infinity" />
               </VBox>
               <VBox alignment="BOTTOM_LEFT">
                  <Button mnemonicParsing="false" styleClass="btn, btn-primary"
                          text="✔ Assigner" onAction="#addWeeklyShift"
                          style="-fx-padding: 10px 20px;" />
               </VBox>
            </HBox>
         </VBox>

         <!-- Timetable -->
         <VBox styleClass="content-row" VBox.vgrow="ALWAYS">
            <HBox styleClass="panel-hdr">
               <Label fx:id="lblWeekTitle" styleClass="section-title" text="Emploi du temps de la semaine" />
            </HBox>

            <!-- Legend -->
            <HBox spacing="16" style="-fx-padding: 0 0 8px 0;" alignment="CENTER_LEFT">
               <HBox spacing="6" alignment="CENTER_LEFT">
                  <Label style="-fx-background-color: #059669; -fx-min-width: 16px; -fx-min-height: 16px; -fx-background-radius: 4px;" text="" />
                  <Label text="Matin (06h-14h)" style="-fx-font-size: 11px; -fx-text-fill: #374151;" />
               </HBox>
               <HBox spacing="6" alignment="CENTER_LEFT">
                  <Label style="-fx-background-color: #0891B2; -fx-min-width: 16px; -fx-min-height: 16px; -fx-background-radius: 4px;" text="" />
                  <Label text="Soir (14h-22h)" style="-fx-font-size: 11px; -fx-text-fill: #374151;" />
               </HBox>
               <HBox spacing="6" alignment="CENTER_LEFT">
                  <Label style="-fx-background-color: #7C3AED; -fx-min-width: 16px; -fx-min-height: 16px; -fx-background-radius: 4px;" text="" />
                  <Label text="Nuit (22h-06h)" style="-fx-font-size: 11px; -fx-text-fill: #374151;" />
               </HBox>
            </HBox>

            <ScrollPane fx:id="spTimetable" fitToWidth="true" styleClass="scroll" VBox.vgrow="ALWAYS" />
         </VBox>

      </VBox>
   </center>

   <bottom>
      <HBox styleClass="app-footer">
         <Label styleClass="footer-label" text="REVIVE — Systeme de Gestion des Urgences Medicales" />
      </HBox>
   </bottom>

</BorderPane>

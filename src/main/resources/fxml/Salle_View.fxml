<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pro.revive.controllers.SalleViewController"
            style="-fx-background-color: #EEF4FB;">

   <!-- ── SIDEBAR ── -->
   <left>
      <VBox styleClass="sidebar" BorderPane.alignment="CENTER">
         <VBox styleClass="logo-wrap">
            <ImageView fitWidth="170.0" preserveRatio="true" pickOnBounds="true">
               <image><Image url="@../images/logo.png" /></image>
            </ImageView>
            <Label styleClass="logo-sub" text="Systeme de Gestion des Urgences" />
         </VBox>
         <Label styleClass="nav-section" text="MENU" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="🏠  Tableau de Bord" onAction="#goDashboard" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="📋  Triages" onAction="#goTriageList" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="➕  Nouveau Triage" onAction="#goTriageAdd" />
         <Button mnemonicParsing="false" styleClass="nav-item, active" text="🏥  Salles d'Attente" onAction="#goSalleList" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="◎  Surveillance" onAction="#goSurveillance" />
         <Label styleClass="nav-section" text="NAVIGATION" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="←  Retour a la Liste" onAction="#goSalleList" />
         <Region VBox.vgrow="ALWAYS" />
         <VBox styleClass="sidebar-card">
            <Label fx:id="lblSideTitle" styleClass="sc-title" text="SALLE" />
            <Label fx:id="lblSideOccup" styleClass="sc-alert" text="..." />
            <Label fx:id="lblSideType"
                   style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 10px; -fx-padding: 0 0 10px 0;" text="..." />
            <Button mnemonicParsing="false" styleClass="sc-btn" text="Deconnexion" onAction="#deconnexion" />
         </VBox>
      </VBox>
   </left>

   <!-- ── MAIN ── -->
   <center>
      <VBox styleClass="main" BorderPane.alignment="CENTER">

         <!-- Topbar -->
         <!-- Topbar -->
         <HBox styleClass="topbar">
            <VBox spacing="2">
               <Label fx:id="lblPageTitle" styleClass="page-title" text="Salle — Details" />
               <Label fx:id="lblPageSub" styleClass="page-sub" text="Lecture seule" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox styleClass="user-chip">
               <VBox alignment="CENTER_RIGHT" styleClass="user-info">
                  <Label fx:id="lblUserName" styleClass="user-name" text="..." />
                  <Label styleClass="user-role" text="Infirmier Triage" />
               </VBox>
               <Label styleClass="user-av" text="U" />
            </HBox>
         </HBox>
         <Region styleClass="topbar-stripe" />

         <ScrollPane fitToWidth="true" styleClass="scroll" VBox.vgrow="ALWAYS">
            <content>
               <HBox spacing="20.0" style="-fx-padding: 20px 28px 28px;">

                  <!-- ── LEFT COLUMN ── -->
                  <VBox spacing="16.0" HBox.hgrow="ALWAYS">

                     <!-- Room Header Card -->
                     <VBox style="-fx-background-color: white; -fx-background-radius: 16px;
                                  -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.10),16,0,0,4);
                                  -fx-padding: 22px;" spacing="14.0">
                        <HBox spacing="16.0" alignment="CENTER_LEFT">
                           <!-- Room Icon -->
                           <Label style="-fx-min-width: 68px; -fx-min-height: 68px;
                                         -fx-background-color: #DBEAFE; -fx-background-radius: 16px;
                                         -fx-alignment: center; -fx-font-size: 32px;" text="🏥" />
                           <VBox HBox.hgrow="ALWAYS" spacing="4.0">
                              <Label fx:id="lblSalleName"
                                     style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="..." />
                              <Label fx:id="lblSalleInfo"
                                     style="-fx-font-size: 12px; -fx-text-fill: #64748B;" text="..." />
                              <HBox spacing="8.0" alignment="CENTER_LEFT">
                                 <Label fx:id="lblSalleStatut" styleClass="rstatus, rs-ok" text="..." />
                              </HBox>
                           </VBox>
                           <!-- Patient Count Badge -->
                           <VBox style="-fx-background-color: #F8FAFC; -fx-background-radius: 14px;
                                        -fx-padding: 14px 22px;" alignment="CENTER" spacing="2">
                              <Label fx:id="lblNombreActuel"
                                     style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #F59E0B;" text="?" />
                              <Label fx:id="lblSurCapacite"
                                     style="-fx-font-size: 12px; -fx-text-fill: #64748B;" text="sur ?" />
                              <Label style="-fx-font-size: 10px; -fx-text-fill: #94A3B8;" text="patients" />
                           </VBox>
                        </HBox>

                        <!-- Occupation Bar -->
                        <VBox spacing="4">
                           <HBox alignment="CENTER">
                              <Label style="-fx-font-size: 12px; -fx-text-fill: #64748B; -fx-font-weight: bold;"
                                     text="Taux d'occupation" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="lblPct"
                                     style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #F59E0B;" text="0%" />
                           </HBox>
                           <ProgressBar fx:id="progressBar" progress="0.0"
                                        styleClass="big-prog, pf-orange" maxWidth="Infinity" />
                        </VBox>

                        <!-- Info Grid -->
                        <GridPane hgap="12.0" vgap="12.0" styleClass="info-grid">
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints minHeight="10.0" prefHeight="54.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10.0" prefHeight="54.0" vgrow="SOMETIMES" />
                           </rowConstraints>
                           <VBox styleClass="info-item" GridPane.columnIndex="0" GridPane.rowIndex="0">
                              <Label styleClass="ii-label" text="Capacite Maximale" />
                              <Label fx:id="lblCapaciteMax" styleClass="ii-val" text="..." />
                           </VBox>
                           <VBox styleClass="info-item" GridPane.columnIndex="1" GridPane.rowIndex="0">
                              <Label styleClass="ii-label" text="Places Disponibles" />
                              <Label fx:id="lblPlacesLibres" styleClass="ii-val"
                                     style="-fx-text-fill: #0E9B8A;" text="..." />
                           </VBox>
                           <VBox styleClass="info-item" GridPane.columnIndex="0" GridPane.rowIndex="1">
                              <Label styleClass="ii-label" text="En Liste d'Attente" />
                              <Label fx:id="lblEnAttente" styleClass="ii-val"
                                     style="-fx-text-fill: #F59E0B;" text="..." />
                           </VBox>
                           <VBox styleClass="info-item" GridPane.columnIndex="1" GridPane.rowIndex="1">
                              <Label styleClass="ii-label" text="Niveau Gravite" />
                              <Label fx:id="lblNiveauGravite" styleClass="badge, b2" text="..." />
                           </VBox>
                        </GridPane>
                     </VBox>

                     <!-- Patients List Card -->
                     <VBox style="-fx-background-color: white; -fx-background-radius: 14px;
                                  -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.10),16,0,0,4);
                                  -fx-padding: 20px;">
                        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 14px 0;">
                           <Label text="👥" style="-fx-font-size: 18px;" />
                           <Label fx:id="lblPatientsTitle"
                                  style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0B4EA2;"
                                  text="Patients dans cette Salle" />
                        </HBox>
                        <VBox fx:id="patientRows" spacing="8.0" />
                     </VBox>

                  </VBox>

                  <!-- ── RIGHT COLUMN ── -->
                  <VBox spacing="14.0" prefWidth="280.0">

                     <!-- Stats Card -->
                     <VBox style="-fx-background-color: white; -fx-background-radius: 14px;
                                  -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.10),16,0,0,4);
                                  -fx-padding: 18px;" spacing="10.0">
                        <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 0 8px 0;">
                           <Label text="📈" style="-fx-font-size: 16px;" />
                           <Label text="Statistiques"
                                  style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0B4EA2;" />
                        </HBox>
                        <HBox style="-fx-padding: 10px; -fx-background-color: #FFF7ED;
                                     -fx-background-radius: 10px;" alignment="CENTER">
                           <Label style="-fx-font-size: 12px; -fx-text-fill: #64748B;" text="Patients actifs" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="statActifs"
                                  style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #F59E0B;" text="0" />
                        </HBox>
                        <HBox style="-fx-padding: 10px; -fx-background-color: #ECFDF5;
                                     -fx-background-radius: 10px;" alignment="CENTER">
                           <Label style="-fx-font-size: 12px; -fx-text-fill: #64748B;" text="Places restantes" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="statLibres"
                                  style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0E9B8A;" text="0" />
                        </HBox>
                        <HBox style="-fx-padding: 10px; -fx-background-color: #EFF6FF;
                                     -fx-background-radius: 10px;" alignment="CENTER">
                           <Label style="-fx-font-size: 12px; -fx-text-fill: #64748B;" text="En consultation" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="statConsult"
                                  style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0B4EA2;" text="0" />
                        </HBox>
                     </VBox>


                  </VBox>

               </HBox>
            </content>
         </ScrollPane>

      </VBox>
   </center>
</BorderPane>

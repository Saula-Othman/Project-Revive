<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pro.revive.controllers.ControllersMed.OrdonnancesDialogController"
            styleClass="main-pane"
            prefWidth="900" prefHeight="580">

    <!-- ══ HEADER ═══════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <!-- Topbar dégradé -->
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Gestion des Consultations" styleClass="header-subtitle"/>
                    <Label text="💊  Ordonnances" styleClass="header-title"/>
                </VBox>
                <Label text="Service des Urgences"
                       style="-fx-background-color: rgba(255,255,255,0.15);
                              -fx-text-fill: white; -fx-font-size: 11px;
                              -fx-background-radius: 20px; -fx-padding: 5px 14px;
                              -fx-border-color: rgba(255,255,255,0.35);
                              -fx-border-radius: 20px; -fx-border-width: 1px;"/>
            </HBox>

            <!-- Bande info consultation -->
            <HBox style="-fx-background-color: white; -fx-padding: 12px 24px;
                         -fx-border-color: transparent transparent #E2E8F0 transparent;
                         -fx-border-width: 0 0 1px 0; -fx-spacing: 24px;"
                  alignment="CENTER_LEFT">
                <VBox spacing="3">
                    <Label fx:id="labelTitreConsultation" text="Consultation #—"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0B4EA2;"/>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="Patient :"
                               style="-fx-text-fill: #94A3B8; -fx-font-size: 12px;"/>
                        <Label fx:id="labelPatient" text="—"
                               style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 12px;"/>
                    </HBox>
                </VBox>
                <Separator orientation="VERTICAL" prefHeight="32"/>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Diagnostic :"
                           style="-fx-text-fill: #94A3B8; -fx-font-size: 12px;"/>
                    <Label fx:id="labelDiagnostic" text="—"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px;"
                           wrapText="true" maxWidth="500"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- ══ TABLEAU ══════════════════════════════════════════════════════ -->
    <center>
        <VBox style="-fx-background-color: #EEF4FB; -fx-padding: 16px 24px 0px 24px;"
              spacing="0">
            <TableView fx:id="tableOrdonnances" VBox.vgrow="ALWAYS"
                       styleClass="table-view">
                <placeholder>
                    <VBox alignment="CENTER" spacing="10" style="-fx-padding: 40px;">
                        <Label text="💊" style="-fx-font-size: 40px; -fx-opacity: 0.25;"/>
                        <Label text="Aucune ordonnance pour cette consultation"
                               style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;"/>
                    </VBox>
                </placeholder>
                <columns>
                    <TableColumn fx:id="colIdOrdo"     text="ID"         prefWidth="60"  minWidth="50"/>
                    <TableColumn fx:id="colMedicament" text="Médicament" prefWidth="220" minWidth="150"/>
                    <TableColumn fx:id="colPosologie"  text="Posologie"  prefWidth="380" minWidth="200"/>
                    <TableColumn fx:id="colDuree"      text="Durée"      prefWidth="100" minWidth="70"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

    <!-- ══ BOUTONS + FOOTER ═════════════════════════════════════════════ -->
    <bottom>
        <VBox>
            <HBox style="-fx-background-color: white; -fx-padding: 14px 24px;
                         -fx-border-color: #E2E8F0 transparent transparent transparent;
                         -fx-border-width: 1px 0 0 0; -fx-spacing: 10px;"
                  alignment="CENTER_LEFT">

                <!-- Boutons actions -->
                <Button fx:id="btnAjouter" text="＋  Ajouter"
                        styleClass="btn-ghost-green"
                        onAction="#onAjouter" prefHeight="36"/>
                <Button fx:id="btnModifier" text="✎  Modifier"
                        styleClass="btn-ghost-blue"
                        onAction="#onModifier" prefHeight="36"/>
                <Button fx:id="btnSupprimer" text="🗑  Supprimer"
                        styleClass="btn-ghost-red"
                        onAction="#onSupprimer" prefHeight="36"/>
                <Button fx:id="btnExportPdf" text="📄  Export PDF"
                        styleClass="btn-ghost-teal"
                        onAction="#onExportPdf" prefHeight="36">
                    <tooltip><Tooltip text="Générer un PDF de l'ordonnance complète"/></tooltip>
                </Button>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Bouton fermer à droite -->
                <Button fx:id="btnFermer" text="✕  Fermer"
                        styleClass="btn-ghost-navy"
                        onAction="#onFermer" prefHeight="36" prefWidth="110"/>
            </HBox>

            <!-- Footer -->
            <HBox styleClass="footer-bar" alignment="CENTER">
                <Label text="REVIVE — Système de Gestion des Urgences"
                       styleClass="footer-label"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>

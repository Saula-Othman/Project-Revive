<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pro.revive.controllers.ControllersMed.ExamenDialogController"
            styleClass="main-pane"
            prefWidth="560" prefHeight="480">

    <!-- HEADER -->
    <top>
        <VBox>
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Demande d'examens" styleClass="header-subtitle"/>
                    <Label fx:id="labelTitre" text="Analyses &amp; Imageries" styleClass="header-title"/>
                </VBox>
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="labelPatient" text="" styleClass="header-badge"/>
                    <Label fx:id="labelConsultation" text="" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 11px;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- CONTENU -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="main-pane"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox styleClass="content-area" spacing="16">

                <!-- Statut actuel -->
                <HBox fx:id="boxStatut" alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #f0fdf4; -fx-background-radius: 8;
                             -fx-border-color: #bbf7d0; -fx-border-radius: 8; -fx-padding: 10 14;">
                    <Label text="Statut :" style="-fx-text-fill: #374151; -fx-font-size: 12px;"/>
                    <Label fx:id="labelStatut" text="Non envoyee"
                           style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                </HBox>

                <!-- Info -->
                <HBox style="-fx-background-color: #eff6ff; -fx-background-radius: 8;
                             -fx-border-color: #bfdbfe; -fx-border-radius: 8; -fx-padding: 10 14;"
                      alignment="CENTER_LEFT" spacing="8">
                    <Label text="i" style="-fx-font-weight: bold; -fx-text-fill: #2563eb; -fx-font-size: 13px;"/>
                    <Label text="Remplissez les champs ci-dessous. Une demande sera envoyee au biologiste/radiologue."
                           style="-fx-text-fill: #1d4ed8; -fx-font-size: 11px;" wrapText="true"
                           HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Analyses biologiques -->
                <VBox styleClass="card" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Analyses biologiques"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #166534;"/>
                        <Label text="NFS, CRP, Troponines..."
                               style="-fx-text-fill: #6b7280; -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Boutons raccourcis analyses -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Button text="NFS" onAction="#ajouterNFS"
                                style="-fx-background-color: #dcfce7; -fx-text-fill: #166534;
                                       -fx-border-color: #86efac; -fx-border-radius: 6;
                                       -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10;"/>
                        <Button text="CRP" onAction="#ajouterCRP"
                                style="-fx-background-color: #dcfce7; -fx-text-fill: #166534;
                                       -fx-border-color: #86efac; -fx-border-radius: 6;
                                       -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10;"/>
                        <Button text="Troponines" onAction="#ajouterTroponines"
                                style="-fx-background-color: #dcfce7; -fx-text-fill: #166534;
                                       -fx-border-color: #86efac; -fx-border-radius: 6;
                                       -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10;"/>
                        <Button text="Bilan hepatique" onAction="#ajouterBilanHepatique"
                                style="-fx-background-color: #dcfce7; -fx-text-fill: #166534;
                                       -fx-border-color: #86efac; -fx-border-radius: 6;
                                       -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10;"/>
                        <Button text="Glycemie" onAction="#ajouterGlycemie"
                                style="-fx-background-color: #dcfce7; -fx-text-fill: #166534;
                                       -fx-border-color: #86efac; -fx-border-radius: 6;
                                       -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10;"/>
                    </HBox>

                    <TextArea fx:id="textAnalyses"
                              promptText="Ex: NFS, CRP, Troponines, Bilan hepatique, Ionogramme..."
                              prefRowCount="4" wrapText="true"
                              style="-fx-border-color: #86efac; -fx-border-radius: 6;
                                     -fx-background-radius: 6;"/>
                </VBox>

                <!-- Imageries medicales -->
                <VBox styleClass="card" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Imageries medicales"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
                        <Label text="Radio, Scanner, IRM..."
                               style="-fx-text-fill: #6b7280; -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Boutons raccourcis imageries -->
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Button text="Radio thorax" onAction="#ajouterRadioThorax"
                                style="-fx-background-color: #dbeafe; -fx-text-fill: #1e40af;
                                       -fx-border-color: #93c5fd; -fx-border-radius: 6;
                                       -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10;"/>
                        <Button text="Scanner cerebral" onAction="#ajouterScannerCerebral"
                                style="-fx-background-color: #dbeafe; -fx-text-fill: #1e40af;
                                       -fx-border-color: #93c5fd; -fx-border-radius: 6;
                                       -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10;"/>
                        <Button text="Echo abdo" onAction="#ajouterEchoAbdo"
                                style="-fx-background-color: #dbeafe; -fx-text-fill: #1e40af;
                                       -fx-border-color: #93c5fd; -fx-border-radius: 6;
                                       -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10;"/>
                        <Button text="IRM lombaire" onAction="#ajouterIRMLombaire"
                                style="-fx-background-color: #dbeafe; -fx-text-fill: #1e40af;
                                       -fx-border-color: #93c5fd; -fx-border-radius: 6;
                                       -fx-background-radius: 6; -fx-font-size: 11px; -fx-padding: 4 10;"/>
                    </HBox>

                    <TextArea fx:id="textImageries"
                              promptText="Ex: Radio thorax, Scanner cerebral, IRM lombaire..."
                              prefRowCount="4" wrapText="true"
                              style="-fx-border-color: #93c5fd; -fx-border-radius: 6;
                                     -fx-background-radius: 6;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- BOUTONS -->
    <bottom>
        <VBox>
            <HBox styleClass="action-bar" spacing="10" alignment="CENTER_RIGHT">
                <padding><Insets top="12" bottom="12" left="20" right="20"/></padding>
                <Button fx:id="btnAnnuler" text="Annuler"
                        styleClass="btn-outline"
                        onAction="#onAnnuler"
                        prefHeight="36" prefWidth="110"/>
                <Button fx:id="btnEnvoyer" text="Envoyer la demande"
                        styleClass="btn-primary"
                        onAction="#onEnvoyer"
                        prefHeight="36" prefWidth="180"/>
            </HBox>
            <HBox styleClass="footer-bar" alignment="CENTER">
                <Label text="REVIVE — Systeme de Gestion des Urgences" styleClass="footer-label"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>

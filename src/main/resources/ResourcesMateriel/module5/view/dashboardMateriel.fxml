<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760" prefWidth="1200" stylesheets="@../css/styleMateriel.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pro.revive.controllers.ControllersMateriel.DashboardController">

    <!-- ══════════════════════════════════════════════════════════════
         SIDEBAR
    ══════════════════════════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="250" spacing="0" styleClass="sidebar">
            <VBox alignment="CENTER" spacing="4" styleClass="logo-wrap">
                <Label styleClass="logo-fallback" text="🏥 REVIVE" />
                <Label styleClass="logo-sub" text="Gestion des Urgences" />
            </VBox>
            <Label styleClass="nav-section" text="NAVIGATION" />
            <Button alignment="CENTER_LEFT" maxWidth="Infinity" styleClass="nav-item, active" text="📊  Tableau de Bord" />
            <Button fx:id="btnNavSalles" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavSalles" styleClass="nav-item" text="🏠  Salles Physiques" />
            <Button fx:id="btnNavMateriel" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavMateriel" styleClass="nav-item" text="🔧  Matériel d'Urgence" />
            <Button fx:id="btnNavAmbulances" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavAmbulances" styleClass="nav-item" text="🚑  Gestion Ambulances" />
            <Button fx:id="btnNavSimulation" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavSimulation" styleClass="nav-item" text="🗺  Simulation Trajet" />
            <Button fx:id="btnNavHistorique" alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavHistorique" styleClass="nav-item" text="📋  Historique Missions" />
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" onAction="#onDeconnexion" styleClass="nav-logout" text="🔓  Déconnexion" />
            <VBox alignment="CENTER" spacing="2" styleClass="sidebar-card">
                <Label styleClass="sc-title" text="Module actif" />
                <Label styleClass="sc-alert" text="Logistique" />
            </VBox>
        </VBox>
    </left>

    <!-- ══════════════════════════════════════════════════════════════
         CONTENU PRINCIPAL
    ══════════════════════════════════════════════════════════════════ -->
    <center>
        <VBox spacing="0">

            <!-- ── TOPBAR ── -->
            <VBox spacing="4" styleClass="topbar">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label styleClass="page-sub" text="Gestion des Salles et Matériel" />
                        <Label styleClass="page-title" text="Tableau de Bord" />
                    </VBox>
                    <HBox alignment="CENTER" spacing="10" styleClass="user-chip">
                        <children>
                            <VBox alignment="CENTER_RIGHT">
                                <children>
                                    <Label fx:id="lblUserName" styleClass="user-name" text="Utilisateur" />
                                    <Label fx:id="lblUserRole" styleClass="user-role" text="Administrateur" />
                                </children>
                            </VBox>
                            <Label fx:id="lblUserInitial" styleClass="user-av" text="U" />
                        </children>
                    </HBox>
                    <Button fx:id="btnRecherche" onAction="#onOuvrirRecherche" style="-fx-background-color: rgba(255,255,255,0.15);                                    -fx-text-fill: white;                                    -fx-border-color: rgba(255,255,255,0.35);                                    -fx-border-width: 1.5; -fx-border-radius: 8;                                    -fx-background-radius: 8;                                    -fx-font-size: 12px; -fx-font-weight: bold;                                    -fx-padding: 8 16; -fx-cursor: hand;" text="🔍  Recherche" />
                </HBox>
            </VBox>

            <!-- ── SCROLL CONTENT ── -->
            <ScrollPane fx:id="scrollContent" fitToWidth="true" style="-fx-background-color: #EEF4FB; -fx-background: #EEF4FB;" styleClass="scroll" VBox.vgrow="ALWAYS">
                <VBox fx:id="dashBody" spacing="28" style="-fx-padding: 28 32; -fx-background-color: #EEF4FB;">

                    <!-- ════════════════════════════════════════════
                         SECTION SALLES
                    ════════════════════════════════════════════ -->
                    <VBox spacing="14">
                        <!-- Titre section -->
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-text-fill: #0B4EA2; -fx-font-size: 15px;                                           -fx-font-weight: bold;" text="🏠  Salles Physiques" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#onNavSalles" style="-fx-background-color: #EEF4FB;                                            -fx-text-fill: #0B4EA2;                                            -fx-font-size: 12px; -fx-font-weight: bold;                                            -fx-cursor: hand; -fx-border-color: #CBD5E1;                                            -fx-border-radius: 6; -fx-background-radius: 6;                                            -fx-border-width: 1; -fx-padding: 4 12;" text="Voir tout →" />
                        </HBox>

                        <!-- 4 cartes salles -->
                        <HBox spacing="16">

                            <!-- Total Salles — bleu -->
                            <VBox fx:id="cardTotalSalles" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-padding: 20 22; -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.08),12,0,0,4);" styleClass="stat-vbox" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane style="-fx-background-color: #EEF4FB; -fx-background-radius: 10; -fx-padding: 8;">
                                        <Label style="-fx-font-size: 20px;" text="🏥" />
                                    </StackPane>
                                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="Total Salles" />
                                </HBox>
                                <Label fx:id="lblTotalSalles" style="-fx-text-fill: #0B4EA2; -fx-font-size: 42px; -fx-font-weight: bold;" text="0" />
                                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" text="salles enregistrées" />
                            </VBox>

                            <!-- Disponibles — vert -->
                            <VBox fx:id="cardSallesDisponibles" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-padding: 20 22; -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.08),12,0,0,4);" styleClass="stat-vbox" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane style="-fx-background-color: #DCFCE7; -fx-background-radius: 10; -fx-padding: 8;">
                                        <Label style="-fx-font-size: 20px;" text="✅" />
                                    </StackPane>
                                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="Disponibles" />
                                </HBox>
                                <Label fx:id="lblSallesDisponibles" style="-fx-text-fill: #16A34A; -fx-font-size: 42px; -fx-font-weight: bold;" text="0" />
                                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" text="prêtes à l'usage" />
                            </VBox>

                            <!-- Occupées — orange -->
                            <VBox fx:id="cardSallesOccupees" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-padding: 20 22; -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.08),12,0,0,4);" styleClass="stat-vbox" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane style="-fx-background-color: #FEF3C7; -fx-background-radius: 10; -fx-padding: 8;">
                                        <Label style="-fx-font-size: 20px;" text="🔴" />
                                    </StackPane>
                                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="Occupées" />
                                </HBox>
                                <Label fx:id="lblSallesOccupees" style="-fx-text-fill: #D97706; -fx-font-size: 42px; -fx-font-weight: bold;" text="0" />
                                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" text="en cours d'utilisation" />
                            </VBox>

                            <!-- Nettoyage — cyan -->
                            <VBox fx:id="cardSallesNettoyage" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-padding: 20 22; -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.08),12,0,0,4);" styleClass="stat-vbox" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane style="-fx-background-color: #E0F2FE; -fx-background-radius: 10; -fx-padding: 8;">
                                        <Label style="-fx-font-size: 20px;" text="🧹" />
                                    </StackPane>
                                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="Nettoyage" />
                                </HBox>
                                <Label fx:id="lblSallesNettoyage" style="-fx-text-fill: #0284C7; -fx-font-size: 42px; -fx-font-weight: bold;" text="0" />
                                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" text="en cours de nettoyage" />
                            </VBox>

                        </HBox>
                    </VBox>

                    <!-- ════════════════════════════════════════════
                         SECTION MATÉRIEL
                    ════════════════════════════════════════════ -->
                    <VBox spacing="14">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-text-fill: #0B4EA2; -fx-font-size: 15px;                                           -fx-font-weight: bold;" text="🔧  Matériel d'Urgence" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#onNavMateriel" style="-fx-background-color: #EEF4FB;                                            -fx-text-fill: #0B4EA2;                                            -fx-font-size: 12px; -fx-font-weight: bold;                                            -fx-cursor: hand; -fx-border-color: #CBD5E1;                                            -fx-border-radius: 6; -fx-background-radius: 6;                                            -fx-border-width: 1; -fx-padding: 4 12;" text="Voir tout →" />
                        </HBox>

                        <HBox spacing="16">

                            <!-- Total équipements — bleu -->
                            <VBox fx:id="cardTotalMateriel" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-padding: 20 22; -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.08),12,0,0,4);" styleClass="stat-vbox" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane style="-fx-background-color: #EEF4FB; -fx-background-radius: 10; -fx-padding: 8;">
                                        <Label style="-fx-font-size: 20px;" text="📦" />
                                    </StackPane>
                                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="Total Équipements" />
                                </HBox>
                                <Label fx:id="lblTotalMateriel" style="-fx-text-fill: #0B4EA2; -fx-font-size: 42px; -fx-font-weight: bold;" text="0" />
                                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" text="équipements inventoriés" />
                            </VBox>

                            <!-- Fonctionnels — vert -->
                            <VBox fx:id="cardMaterielFonc" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-padding: 20 22; -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.08),12,0,0,4);" styleClass="stat-vbox" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane style="-fx-background-color: #DCFCE7; -fx-background-radius: 10; -fx-padding: 8;">
                                        <Label style="-fx-font-size: 20px;" text="✅" />
                                    </StackPane>
                                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="Fonctionnels" />
                                </HBox>
                                <Label fx:id="lblMaterielFonctionnel" style="-fx-text-fill: #16A34A; -fx-font-size: 42px; -fx-font-weight: bold;" text="0" />
                                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" text="en bon état" />
                            </VBox>

                            <!-- À réviser — rouge -->
                            <VBox fx:id="cardMaterielRev" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-padding: 20 22; -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.08),12,0,0,4);" styleClass="stat-vbox" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane style="-fx-background-color: #FEE2E2; -fx-background-radius: 10; -fx-padding: 8;">
                                        <Label style="-fx-font-size: 20px;" text="⚠️" />
                                    </StackPane>
                                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="À Réviser" />
                                </HBox>
                                <Label fx:id="lblMaterielAReviser" style="-fx-text-fill: #DC2626; -fx-font-size: 42px; -fx-font-weight: bold;" text="0" />
                                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" text="nécessitent maintenance" />
                            </VBox>

                            <!-- En réserve — violet -->
                            <VBox fx:id="cardMaterielRes" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-padding: 20 22; -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.08),12,0,0,4);" styleClass="stat-vbox" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane style="-fx-background-color: #EDE9FE; -fx-background-radius: 10; -fx-padding: 8;">
                                        <Label style="-fx-font-size: 20px;" text="🗄" />
                                    </StackPane>
                                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="En Réserve" />
                                </HBox>
                                <Label fx:id="lblMaterielReserve" style="-fx-text-fill: #7C3AED; -fx-font-size: 42px; -fx-font-weight: bold;" text="0" />
                                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" text="non affectés" />
                            </VBox>

                        </HBox>
                    </VBox>

                    <!-- ════════════════════════════════════════════
                         SECTION GRAPHIQUES
                    ════════════════════════════════════════════ -->
                    <VBox spacing="14">
                        <Label style="-fx-text-fill: #0B4EA2; -fx-font-size: 15px;                                       -fx-font-weight: bold;" text="📊  Analyses Graphiques" />

                        <HBox spacing="20">

                            <!-- PieChart -->
                            <VBox spacing="12" style="-fx-background-color: white;                                          -fx-background-radius: 16;                                          -fx-border-radius: 16;                                          -fx-border-color: #E2E8F0;                                          -fx-border-width: 1;                                          -fx-padding: 22 24;                                          -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.08),12,0,0,4);" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-text-fill: #1E293B;                                                   -fx-font-size: 13px;                                                   -fx-font-weight: bold;" text="Répartition des Statuts de Salles" HBox.hgrow="ALWAYS" />
                                </HBox>
                                <PieChart fx:id="pieStatutSalles" labelsVisible="true" legendVisible="true" prefHeight="300" style="-fx-background-color: transparent;" />
                            </VBox>

                            <!-- BarChart -->
                            <VBox spacing="12" style="-fx-background-color: white;                                          -fx-background-radius: 16;                                          -fx-border-radius: 16;                                          -fx-border-color: #E2E8F0;                                          -fx-border-width: 1;                                          -fx-padding: 22 24;                                          -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.08),12,0,0,4);" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-text-fill: #1E293B;                                                   -fx-font-size: 13px;                                                   -fx-font-weight: bold;" text="Matériel par Salle" HBox.hgrow="ALWAYS" />
                                </HBox>
                                <BarChart fx:id="barMaterielParSalle" legendVisible="true" prefHeight="300" style="-fx-background-color: transparent;">
                                    <xAxis>
                                        <CategoryAxis label="Salle" style="-fx-tick-label-fill: #64748B;                                                              -fx-font-size: 11px;" />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis label="Quantité" style="-fx-tick-label-fill: #64748B;                                                            -fx-font-size: 11px;" />
                                    </yAxis>
                                </BarChart>
                            </VBox>

                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

    <!-- ══════════════════════════════════════════════════════════════
         FOOTER
    ══════════════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 8;                      -fx-background-color: linear-gradient(to right, #0B4EA2, #0E9B8A);">
            <Label style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 11px;" text="REVIVE — Système de Gestion des Urgences" />
        </HBox>
    </bottom>

</BorderPane>

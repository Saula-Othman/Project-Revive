<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../css/styleMateriel.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pro.revive.controllers.ControllersMateriel.HistoriqueMissionsController">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="250" spacing="0" styleClass="sidebar">
            <VBox alignment="CENTER" spacing="4" styleClass="logo-wrap">
                <Label styleClass="logo-fallback" text="🏥 REVIVE" />
                <Label styleClass="logo-sub" text="Gestion des Urgences" />
            </VBox>
            <Label styleClass="nav-section" text="NAVIGATION" />
            <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavDashboard" styleClass="nav-item" text="📊  Tableau de Bord" />
            <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavSalles" styleClass="nav-item" text="🏠  Salles Physiques" />
            <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavMateriel" styleClass="nav-item" text="🔧  Matériel d'Urgence" />
            <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavAmbulances" styleClass="nav-item" text="🚑  Gestion Ambulances" />
            <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onNavSimulation" styleClass="nav-item" text="🗺  Simulation Trajet" />
            <Button alignment="CENTER_LEFT" maxWidth="Infinity" styleClass="nav-item, active" text="📋  Historique Missions" />
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" onAction="#onDeconnexion" styleClass="nav-logout" text="🔓  Déconnexion" />
            <VBox alignment="CENTER" spacing="2" styleClass="sidebar-card">
                <Label styleClass="sc-title" text="Module actif" />
                <Label styleClass="sc-alert" text="Logistique" />
            </VBox>
        </VBox>
    </left>

    <!-- CONTENU -->
    <center>
        <VBox spacing="0">

            <!-- HEADER -->
            <VBox spacing="4" styleClass="topbar">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label styleClass="page-sub" text="Ambulances &amp; Missions" />
                        <Label styleClass="page-title" text="Historique des Missions" />
                    </VBox>
                    <HBox alignment="CENTER" spacing="10" styleClass="user-chip">
                        <children>
                            <VBox alignment="CENTER_RIGHT">
                                <children>
                                    <Label fx:id="lblUserName" styleClass="user-name" text="Utilisateur" />
                                    <Label fx:id="lblUserRole" styleClass="user-role" text="Administrateur" />
                                </children>
                            </VBox>
                            <Label fx:id="lblUserInitial" styleClass="user-av" text="U" />
                        </children>
                    </HBox>
                    <Button onAction="#onExportPdf" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;                                    -fx-border-color: rgba(255,255,255,0.40); -fx-border-width: 1px;                                    -fx-border-radius: 8px; -fx-background-radius: 8px;                                    -fx-font-size: 13px; -fx-font-weight: bold;                                    -fx-padding: 9px 18px; -fx-cursor: hand;" text="📄  Exporter PDF" />
                </HBox>
            </VBox>

            <!-- FILTRES -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10px 18px; -fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0; -fx-spacing: 10px;">
                <Label style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#334155;" text="Ambulance :" />
                <ComboBox fx:id="cmbFiltreAmbulance" prefWidth="185" promptText="Toutes les ambulances" styleClass="combo-box" />
                <Label style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#334155;" text="Statut :" />
                <ComboBox fx:id="cmbFiltreStatut" prefWidth="135" promptText="Tous les statuts" styleClass="combo-box" />
                <Label style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#334155;" text="Du :" />
                <DatePicker fx:id="dpDebut" prefWidth="125" promptText="jj/mm/aaaa" />
                <Label style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#334155;" text="Au :" />
                <DatePicker fx:id="dpFin" prefWidth="125" promptText="jj/mm/aaaa" />
                <Button onAction="#onFiltrer" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;                                -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;" text="🔍 Filtrer" />
                <Button onAction="#onReinitialiser" style="-fx-background-color: transparent; -fx-border-color: #cbd5e1;                                -fx-border-radius: 8; -fx-text-fill: #94a3b8;                                -fx-padding: 8 12; -fx-cursor: hand; -fx-font-size: 14px;" text="✖" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTotal" styleClass="stat-hint" text="0 mission(s)" />
            </HBox>

            <!-- STATS RAPIDES -->
            <HBox spacing="16" style="-fx-padding: 16 30; -fx-background-color: #EEF4FB;">
                <VBox spacing="5" styleClass="stat-card, blue" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 18px;" text="📋" />
                        <Label styleClass="stat-lbl" text="TOTAL MISSIONS" />
                    </HBox>
                    <Label fx:id="lblTotalMissions" style="-fx-font-size: 32px;" styleClass="stat-val, blue" text="0" />
                    <Label styleClass="stat-hint" text="missions enregistrées" />
                </VBox>
                <VBox spacing="5" styleClass="stat-card, green" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 18px;" text="📏" />
                        <Label styleClass="stat-lbl" text="DISTANCE TOTALE" />
                    </HBox>
                    <Label fx:id="lblDistanceTotale" style="-fx-font-size: 26px;" styleClass="stat-val, green" text="0 km" />
                    <Label styleClass="stat-hint" text="kilomètres parcourus" />
                </VBox>
                <VBox spacing="5" styleClass="stat-card, blue" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 18px;" text="⏱" />
                        <Label styleClass="stat-lbl" text="DURÉE MOYENNE" />
                    </HBox>
                    <Label fx:id="lblDureeMoyenne" style="-fx-font-size: 26px;" styleClass="stat-val, blue" text="0 min" />
                    <Label styleClass="stat-hint" text="par mission" />
                </VBox>
                <VBox spacing="5" styleClass="stat-card, orange" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 18px;" text="📅" />
                        <Label styleClass="stat-lbl" text="AUJOURD'HUI" />
                    </HBox>
                    <Label fx:id="lblMissionsAujourdhui" style="-fx-font-size: 32px;" styleClass="stat-val, orange" text="0" />
                    <Label styleClass="stat-hint" text="missions ce jour" />
                </VBox>
            </HBox>

            <!-- TABLEAU -->
            <VBox style="-fx-padding: 0 30 16 30; -fx-background-color: #EEF4FB;" VBox.vgrow="ALWAYS">
                <TableView fx:id="tableHistorique" fixedCellSize="40" style="-fx-background-color: white; -fx-background-radius: 12;                                   -fx-border-color: #e2e8f0; -fx-border-radius: 12;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDate" text="📅 Date" />
                        <TableColumn fx:id="colAmbulance" text="🚑 Ambulance" />
                        <TableColumn fx:id="colDepart" text="🏥 Départ" />
                        <TableColumn fx:id="colUrgence" text="🚨 Urgence" />
                        <TableColumn fx:id="colDistance" text="📏 Distance" />
                        <TableColumn fx:id="colDuree" text="⏱ Durée" />
                        <TableColumn fx:id="colStatut" text="📌 Statut" />
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="12" style="-fx-padding: 40;">
                            <Label style="-fx-font-size: 40px;" text="📋" />
                            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #64748b;" text="Aucune mission trouvée" />
                            <Label style="-fx-text-fill: #94a3b8;" text="Modifiez les filtres ou lancez une simulation" />
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- FOOTER -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 8px 18px; -fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-width: 1 0 0 0;">
                <Label fx:id="lblFooter" styleClass="stat-hint" text="Cliquez sur une ligne pour voir les détails" />
            </HBox>

        </VBox>
    </center>

    <!-- FOOTER APP -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 8px; -fx-background-color: linear-gradient(to bottom, #0B4EA2, #0E9B8A);">
            <Label style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 11px;" text="REVIVE — Historique des Missions" />
        </HBox>
    </bottom>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane stylesheets="@../css/styleMateriel.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pro.revive.controllers.ControllersMateriel.AmbulanceListController">
   <children>
      <BorderPane>
         <left>
            <VBox prefWidth="250" spacing="0" styleClass="sidebar">
               <children>
                  <VBox alignment="CENTER" spacing="4" styleClass="logo-wrap">
                     <children>
                        <Label styleClass="logo-fallback" text="🏥 REVIVE" />
                        <Label styleClass="logo-sub" text="Gestion des Urgences" />
                     </children>
                  </VBox>
                  <Label styleClass="nav-section" text="NAVIGATION" />
                  <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onVoirDashboard" styleClass="nav-item" text="📊  Tableau de Bord" />
                  <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onVoirSalles" styleClass="nav-item" text="🏠  Salles Physiques" />
                  <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onVoirMateriel" styleClass="nav-item" text="🔧  Matériel d'Urgence" />
                  <Button alignment="CENTER_LEFT" maxWidth="Infinity" styleClass="nav-item, active" text="🚑  Ambulances" />
                  <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onVoirSimulation" styleClass="nav-item" text="🗺  Simulation Trajet" />
                  <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onVoirHistorique" styleClass="nav-item" text="📋  Historique Missions" />
                  <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#onVoirRecherche" styleClass="nav-item" text="🔍  Recherche Globale" />
                  <Region VBox.vgrow="ALWAYS" />
                  <Button maxWidth="Infinity" onAction="#onDeconnexion" styleClass="nav-logout" text="🔓  Déconnexion" />
                  <VBox alignment="CENTER" spacing="2" styleClass="sidebar-card">
                     <children>
                        <Label styleClass="sc-title" text="Module actif" />
                        <Label styleClass="sc-alert" text="Logistique" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </left>
         <center>
            <VBox spacing="0">
               <children>
                  <!-- HEADER -->
                  <VBox spacing="4" styleClass="topbar">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="16">
                           <children>
                              <VBox spacing="2" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="page-sub" text="Gestion de la Flotte" />
                                    <Label styleClass="page-title" text="Ambulances &amp; Maintenance IA" />
                                 </children>
                              </VBox>
                              <HBox alignment="CENTER" spacing="10" styleClass="user-chip">
                                 <children>
                                    <VBox alignment="CENTER_RIGHT">
                                       <children>
                                          <Label fx:id="lblUserName" styleClass="user-name" text="Utilisateur" />
                                          <Label fx:id="lblUserRole" styleClass="user-role" text="Administrateur" />
                                       </children>
                                    </VBox>
                                    <Label fx:id="lblUserInitial" styleClass="user-av" text="U" />
                                 </children>
                              </HBox>
                              <Button onAction="#onAjouter" styleClass="btn, btn-secondary" text="➕  Nouvelle Ambulance" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- STATS CARDS -->
                  <HBox spacing="16" style="-fx-padding: 20 24 16 24; -fx-background-color: #EEF4FB;">
                     <children>
                        <VBox spacing="6" styleClass="stat-card, blue" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10">
                                 <Label style="-fx-font-size: 22px;" text="🚑" />
                                 <Label styleClass="stat-lbl" text="TOTAL" />
                              </HBox>
                              <Label fx:id="lblTotalAmbulances" styleClass="stat-val, blue" text="0" />
                              <Label styleClass="stat-hint" text="Dans la flotte" />
                           </children>
                        </VBox>
                        <VBox spacing="6" styleClass="stat-card, green" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10">
                                 <Label style="-fx-font-size: 22px;" text="✅" />
                                 <Label styleClass="stat-lbl" text="DISPONIBLES" />
                              </HBox>
                              <Label fx:id="lblDisponibles" styleClass="stat-val, green" text="0" />
                              <Label styleClass="stat-hint" text="Prêtes à partir" />
                           </children>
                        </VBox>
                        <VBox spacing="6" styleClass="stat-card, blue" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10">
                                 <Label style="-fx-font-size: 22px;" text="🗺" />
                                 <Label styleClass="stat-lbl" text="EN ROUTE" />
                              </HBox>
                              <Label fx:id="lblEnRoute" styleClass="stat-val, blue" text="0" />
                              <Label styleClass="stat-hint" text="En mission active" />
                           </children>
                        </VBox>
                        <VBox spacing="6" styleClass="stat-card, red" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10">
                                 <Label style="-fx-font-size: 22px;" text="⚠️" />
                                 <Label styleClass="stat-lbl" text="ALERTES IA" />
                              </HBox>
                              <Label fx:id="lblAlertes" styleClass="stat-val, red" text="0" />
                              <Label styleClass="stat-hint" text="Maintenance requise" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <!-- SEARCH BAR AMÉLIORÉE -->
                  <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 14 24; -fx-background-color: white;                                -fx-border-color: transparent transparent #e8edf2 transparent;                                -fx-border-width: 0 0 1 0;">
                     <children>
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #94a3b8;" text="🔍" />
                        <TextField fx:id="txtSearch" promptText="Rechercher par numéro de série, marque, modèle..." styleClass="text-field" HBox.hgrow="ALWAYS" />
                        <Label style="-fx-text-fill: #e2e8f0; -fx-font-size: 20px;" text="|" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: bold;" text="État :" />
                        <ComboBox fx:id="cmbFiltreEtat" prefWidth="170" promptText="Tous les états" styleClass="combo-box" />
                     </children>
                  </HBox>

                  <!-- CARDS CONTAINER -->
                  <VBox style="-fx-background-color: #EEF4FB;" VBox.vgrow="ALWAYS">
                     <children>
                        <ScrollPane fitToWidth="true" styleClass="scroll" VBox.vgrow="ALWAYS">
                           <content>
                              <FlowPane fx:id="cardContainer" hgap="22" style="-fx-padding: 24px; -fx-background-color: #EEF4FB;" vgap="22" />
                           </content>
                        </ScrollPane>
                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 10px 24px; -fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-width: 1 0 0 0;">
                           <children>
                              <Label fx:id="lblTotal" styleClass="stat-hint" text="Total : 0 ambulance(s)" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </center>
      </BorderPane>
   </children>
</StackPane>

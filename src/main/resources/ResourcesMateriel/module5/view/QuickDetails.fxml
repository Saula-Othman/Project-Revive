<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    QuickDetails — Popup détails Salle / Matériel
    Design : fond blanc, header dégradé bleu, styles inline autonomes
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pro.revive.controllers.ControllersMateriel.QuickDetailsController"
      prefWidth="520" spacing="0"
      style="-fx-background-color: white;
             -fx-background-radius: 18;
             -fx-border-radius: 18;
             -fx-border-color: #E2E8F0;
             -fx-border-width: 1;
             -fx-effect: dropshadow(gaussian, rgba(11,78,162,0.25), 40, 0, 0, 12);">

    <!-- ══ HEADER ══════════════════════════════════════════════════ -->
    <VBox style="-fx-background-color: linear-gradient(to right, #0B4EA2, #0E9B8A);
                 -fx-background-radius: 18 18 0 0;
                 -fx-padding: 24 28;">
        <HBox alignment="CENTER_LEFT" spacing="18">

            <!-- Icône dans un cercle -->
            <StackPane style="-fx-background-color: rgba(255,255,255,0.18);
                              -fx-background-radius: 14;
                              -fx-padding: 12;
                              -fx-min-width: 56; -fx-min-height: 56;">
                <Label fx:id="lblHeaderIcon" text="🏠"
                       style="-fx-font-size: 28px;"/>
            </StackPane>

            <!-- Titre + badge -->
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label fx:id="lblTitle" text="Nom de l'élément"
                       style="-fx-text-fill: white;
                              -fx-font-size: 20px;
                              -fx-font-weight: bold;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="lblStatutBadge" text="DISPONIBLE"
                           style="-fx-background-color: rgba(255,255,255,0.25);
                                  -fx-text-fill: white;
                                  -fx-font-size: 10px;
                                  -fx-font-weight: bold;
                                  -fx-padding: 3 12;
                                  -fx-background-radius: 20;"/>
                    <Label fx:id="lblSubtitle" text="Type ou catégorie"
                           style="-fx-text-fill: rgba(255,255,255,0.75);
                                  -fx-font-size: 12px;"/>
                </HBox>
            </VBox>

        </HBox>
    </VBox>

    <!-- ══ BODY ════════════════════════════════════════════════════ -->
    <VBox spacing="16" style="-fx-padding: 24 28; -fx-background-color: white;">

        <!-- Ligne d'infos : 2 cartes côte à côte -->
        <HBox spacing="14">

            <!-- Carte 1 : Occupation / Quantité -->
            <VBox spacing="8" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F8FAFC;
                         -fx-background-radius: 12;
                         -fx-border-color: #E2E8F0;
                         -fx-border-radius: 12;
                         -fx-border-width: 1;
                         -fx-padding: 14 16;">
                <Label fx:id="lblDetail1Label" text="OCCUPATION"
                       style="-fx-text-fill: #64748B;
                              -fx-font-size: 10px;
                              -fx-font-weight: bold;
                              -fx-letter-spacing: 0.5;"/>
                <Label fx:id="lblDetail1Value" text="0 / 0"
                       style="-fx-text-fill: #0B4EA2;
                              -fx-font-size: 18px;
                              -fx-font-weight: bold;"/>
                <ProgressBar fx:id="progressCapacity" progress="0.0"
                             maxWidth="Infinity" prefHeight="6"
                             style="-fx-accent: #0B4EA2;"/>
            </VBox>

            <!-- Carte 2 : Localisation / Emplacement -->
            <VBox spacing="8" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F8FAFC;
                         -fx-background-radius: 12;
                         -fx-border-color: #E2E8F0;
                         -fx-border-radius: 12;
                         -fx-border-width: 1;
                         -fx-padding: 14 16;">
                <Label fx:id="lblDetail2Label" text="LOCALISATION"
                       style="-fx-text-fill: #64748B;
                              -fx-font-size: 10px;
                              -fx-font-weight: bold;
                              -fx-letter-spacing: 0.5;"/>
                <Label fx:id="lblDetail2Value" text="---"
                       style="-fx-text-fill: #1E293B;
                              -fx-font-size: 15px;
                              -fx-font-weight: bold;
                              -fx-wrap-text: true;"/>
            </VBox>

        </HBox>

        <!-- Section équipements (salle uniquement) -->
        <VBox fx:id="cardExtra" spacing="10"
              style="-fx-background-color: #F8FAFC;
                     -fx-background-radius: 12;
                     -fx-border-color: #E2E8F0;
                     -fx-border-radius: 12;
                     -fx-border-width: 1;
                     -fx-padding: 14 16;">
            <HBox alignment="CENTER_LEFT">
                <Label text="ÉQUIPEMENTS DANS CETTE SALLE"
                       style="-fx-text-fill: #64748B;
                              -fx-font-size: 10px;
                              -fx-font-weight: bold;"
                       HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Label fx:id="lblExtraValue" text="0"
                       style="-fx-font-weight: bold;
                              -fx-text-fill: #0B4EA2;
                              -fx-font-size: 14px;
                              -fx-background-color: #EEF4FB;
                              -fx-padding: 2 10;
                              -fx-background-radius: 20;"/>
            </HBox>
            <ScrollPane fitToWidth="true" prefHeight="140"
                        style="-fx-background-color: transparent;
                               -fx-background: transparent;
                               -fx-border-color: transparent;">
                <VBox fx:id="vboxEquipment" spacing="8"
                      style="-fx-padding: 4 0;"/>
            </ScrollPane>
        </VBox>

        <!-- Avertissement (salle occupée) -->
        <HBox fx:id="boxWarning" spacing="14" alignment="CENTER_LEFT"
              visible="false" managed="false"
              style="-fx-background-color: #FEF2F2;
                     -fx-background-radius: 10;
                     -fx-border-color: #FECACA;
                     -fx-border-radius: 10;
                     -fx-border-width: 1;
                     -fx-padding: 12 16;">
            <Label text="⚠️" style="-fx-font-size: 20px;"/>
            <Label fx:id="lblWarning"
                   text="Action bloquée : cette salle n'est pas vide."
                   HBox.hgrow="ALWAYS"
                   style="-fx-text-fill: #991B1B;
                          -fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-wrap-text: true;"/>
        </HBox>

    </VBox>

    <!-- ══ FOOTER ══════════════════════════════════════════════════ -->
    <HBox spacing="12" alignment="CENTER_RIGHT"
          style="-fx-background-color: #F8FAFC;
                 -fx-background-radius: 0 0 18 18;
                 -fx-border-color: #E2E8F0 transparent transparent transparent;
                 -fx-border-width: 1 0 0 0;
                 -fx-padding: 16 24;">

        <Button text="✕  Fermer" onAction="#onClose"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #64748B;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-padding: 10 22;
                       -fx-background-radius: 10;
                       -fx-border-color: #CBD5E1;
                       -fx-border-radius: 10;
                       -fx-border-width: 1.5;
                       -fx-cursor: hand;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Button fx:id="btnEdit" text="✏  Modifier" onAction="#onEdit"
                style="-fx-background-color: #0B4EA2;
                       -fx-text-fill: white;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-padding: 10 24;
                       -fx-background-radius: 10;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(11,78,162,0.3), 8, 0, 0, 3);"/>

        <Button fx:id="btnDelete" text="🗑  Supprimer" onAction="#onDelete"
                style="-fx-background-color: #EF4444;
                       -fx-text-fill: white;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-padding: 10 24;
                       -fx-background-radius: 10;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(239,68,68,0.3), 8, 0, 0, 3);"/>

    </HBox>

</VBox>

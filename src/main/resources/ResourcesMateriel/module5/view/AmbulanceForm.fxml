<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../css/styleMateriel.css"
      fx:controller="pro.revive.controllers.ControllersMateriel.AmbulanceFormController"
      spacing="0" prefWidth="600" style="-fx-background-color: #0f172a; -fx-background-radius: 12;">

   <!-- HEADER -->
   <VBox spacing="6" style="-fx-background-color: #8b5cf6; -fx-background-radius: 12 12 0 0; -fx-padding: 20 24 20 24;">
      <Label fx:id="lblTitre" text="🚑  NOUVELLE AMBULANCE" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
      <Label text="Enregistrer une nouvelle ambulance dans la flotte" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;" />
   </VBox>

   <!-- FORM -->
   <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
      <VBox spacing="20" style="-fx-padding: 24;">

         <!-- Informations générales -->
         <VBox spacing="12">
            <Label text="📋  INFORMATIONS GÉNÉRALES" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;" />
            
            <VBox spacing="6">
               <Label text="Numéro de série *" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
               <TextField fx:id="txtNumeroSerie" promptText="Ex: AMB-005-TN" 
                          style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #64748b; 
                                 -fx-border-color: #334155; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;" />
            </VBox>

            <HBox spacing="12">
               <VBox spacing="6" HBox.hgrow="ALWAYS">
                  <Label text="Marque *" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
                  <ComboBox fx:id="cmbMarque" promptText="Sélectionner une marque" prefWidth="9999" editable="true"
                            style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #64748b; 
                                   -fx-border-color: #334155; -fx-border-radius: 6; -fx-background-radius: 6;" />
               </VBox>
               <VBox spacing="6" HBox.hgrow="ALWAYS">
                  <Label text="Modèle" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
                  <TextField fx:id="txtModele" promptText="Ex: Sprinter 316 CDI" 
                             style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #64748b; 
                                    -fx-border-color: #334155; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;" />
               </VBox>
            </HBox>

            <HBox spacing="12">
               <VBox spacing="6" HBox.hgrow="ALWAYS">
                  <Label text="Année de fabrication" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
                  <TextField fx:id="txtAnnee" promptText="Ex: 2023" 
                             style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #64748b; 
                                    -fx-border-color: #334155; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;" />
               </VBox>
               <VBox spacing="6" HBox.hgrow="ALWAYS">
                  <Label text="État initial" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
                  <ComboBox fx:id="cmbEtat" prefWidth="9999" 
                            style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #64748b; 
                                   -fx-border-color: #334155; -fx-border-radius: 6; -fx-background-radius: 6;" />
               </VBox>
            </HBox>
         </VBox>

         <Separator style="-fx-background-color: #334155;" />

         <!-- Kilométrage -->
         <VBox spacing="12">
            <Label text="📏  KILOMÉTRAGE" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;" />
            
            <VBox spacing="6">
               <Label text="Kilométrage total actuel" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
               <TextField fx:id="txtKmTotal" text="0" 
                          style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #64748b; 
                                 -fx-border-color: #334155; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;" />
            </VBox>
         </VBox>

         <Separator style="-fx-background-color: #334155;" />

         <!-- Maintenance -->
         <VBox spacing="12">
            <Label text="🔧  HISTORIQUE MAINTENANCE (Optionnel)" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;" />
            
            <HBox spacing="12">
               <VBox spacing="6" HBox.hgrow="ALWAYS">
                  <Label text="Date dernière vidange" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
                  <DatePicker fx:id="dpVidange" prefWidth="9999"
                              style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #64748b; 
                                     -fx-border-color: #334155; -fx-border-radius: 6; -fx-background-radius: 6;" />
               </VBox>
               <VBox spacing="6" HBox.hgrow="ALWAYS">
                  <Label text="KM à la dernière vidange" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
                  <TextField fx:id="txtKmVidange" text="0" 
                             style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #64748b; 
                                    -fx-border-color: #334155; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;" />
               </VBox>
            </HBox>

            <HBox spacing="12">
               <VBox spacing="6" HBox.hgrow="ALWAYS">
                  <Label text="Date derniers pneus" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
                  <DatePicker fx:id="dpPneus" prefWidth="9999"
                              style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #64748b; 
                                     -fx-border-color: #334155; -fx-border-radius: 6; -fx-background-radius: 6;" />
               </VBox>
               <VBox spacing="6" HBox.hgrow="ALWAYS">
                  <Label text="KM aux derniers pneus" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
                  <TextField fx:id="txtKmPneus" text="0" 
                             style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-prompt-text-fill: #64748b; 
                                    -fx-border-color: #334155; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;" />
               </VBox>
            </HBox>
         </VBox>

         <!-- BUTTONS -->
         <HBox spacing="12" style="-fx-padding: 12 0 0 0;">
            <Button fx:id="btnSave" text="✅  Enregistrer" onAction="#onSave" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; 
                           -fx-font-size: 13px; -fx-padding: 14; -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button text="❌  Annuler" onAction="#onCancel" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; 
                           -fx-font-size: 13px; -fx-padding: 14; -fx-background-radius: 8; -fx-cursor: hand;" />
         </HBox>

      </VBox>
   </ScrollPane>

</VBox>
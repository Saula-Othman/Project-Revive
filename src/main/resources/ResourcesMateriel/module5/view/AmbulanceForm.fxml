<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      stylesheets="@../css/styleMateriel.css"
      fx:controller="pro.revive.controllers.ControllersMateriel.AmbulanceFormController"
      spacing="0" prefWidth="650" styleClass="form-container">

   <!-- HEADER -->
   <VBox spacing="8" styleClass="form-header">
      <children>
         <HBox spacing="15" alignment="CENTER_LEFT">
            <children>
               <Label fx:id="lblTitre" text="🚑  NOUVELLE AMBULANCE" styleClass="form-header-title" />
            </children>
         </HBox>
         <Label text="Enregistrer une nouvelle ambulance dans le système de gestion de flotte." styleClass="form-header-sub" />
      </children>
   </VBox>

   <!-- FORM BODY -->
   <ScrollPane fitToWidth="true" styleClass="scroll">
      <content>
         <VBox spacing="25" styleClass="form-body">
            <children>
               
               <!-- SECTION 1: VEHICLE INFO -->
               <VBox spacing="15" styleClass="form-section-card">
                  <children>
                     <Label text="🚗  INFORMATIONS DU VÉHICULE" styleClass="form-section-title" />
                     
                     <VBox spacing="15">
                        <children>
                           <VBox styleClass="form-field-group">
                              <children>
                                 <Label text="Numéro de série *" styleClass="form-label" />
                                 <TextField fx:id="txtNumeroSerie" promptText="Format: AMB-XXX-TN" styleClass="form-text-field" />
                              </children>
                           </VBox>
                           
                           <HBox spacing="20">
                              <children>
                                 <VBox styleClass="form-field-group" HBox.hgrow="ALWAYS">
                                    <children>
                                       <Label text="Marque *" styleClass="form-label" />
                                       <ComboBox fx:id="cmbMarque" promptText="Sélectionner" maxWidth="Infinity" styleClass="form-combo-box" />
                                    </children>
                                 </VBox>
                                 <VBox styleClass="form-field-group" HBox.hgrow="ALWAYS">
                                    <children>
                                       <Label text="Modèle" styleClass="form-label" />
                                       <TextField fx:id="txtModele" promptText="Ex: Sprinter" styleClass="form-text-field" />
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>
                           
                           <HBox spacing="20">
                              <children>
                                 <VBox styleClass="form-field-group" HBox.hgrow="ALWAYS">
                                    <children>
                                       <Label text="Année" styleClass="form-label" />
                                       <TextField fx:id="txtAnnee" promptText="2023" styleClass="form-text-field" />
                                    </children>
                                 </VBox>
                                 <VBox styleClass="form-field-group" HBox.hgrow="ALWAYS">
                                    <children>
                                       <Label text="Statut Initial" styleClass="form-label" />
                                       <ComboBox fx:id="cmbEtat" maxWidth="Infinity" styleClass="form-combo-box" />
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>
                        </children>
                     </VBox>
                  </children>
               </VBox>

               <!-- SECTION 2: MILEAGE -->
               <VBox spacing="15" styleClass="form-section-card">
                  <children>
                     <Label text="📏  SUIVI KILOMÉTRIQUE" styleClass="form-section-title" />
                     <VBox styleClass="form-field-group">
                        <children>
                           <Label text="Kilométrage total actuel (KM)" styleClass="form-label" />
                           <TextField fx:id="txtKmTotal" text="0" styleClass="form-text-field" />
                        </children>
                     </VBox>
                  </children>
               </VBox>

               <!-- SECTION 3: MAINTENANCE -->
               <VBox spacing="15" styleClass="form-section-card">
                  <children>
                     <Label text="🔧  ENTRETIEN &amp; MAINTENANCE" styleClass="form-section-title" />
                     
                     <GridPane hgap="20" vgap="15">
                        <columnConstraints>
                           <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                           <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="50.0" />
                        </columnConstraints>
                        <children>
                           <!-- Vidange -->
                           <VBox styleClass="form-field-group" GridPane.columnIndex="0" GridPane.rowIndex="0">
                              <children>
                                 <Label text="Date dernière vidange" styleClass="form-label" />
                                 <DatePicker fx:id="dpVidange" maxWidth="Infinity" styleClass="form-date-picker" />
                              </children>
                           </VBox>
                           <VBox styleClass="form-field-group" GridPane.columnIndex="1" GridPane.rowIndex="0">
                              <children>
                                 <Label text="KM à la vidange" styleClass="form-label" />
                                 <TextField fx:id="txtKmVidange" text="0" styleClass="form-text-field" />
                              </children>
                           </VBox>
                           
                           <!-- Pneus -->
                           <VBox styleClass="form-field-group" GridPane.columnIndex="0" GridPane.rowIndex="1">
                              <children>
                                 <Label text="Date derniers pneus" styleClass="form-label" />
                                 <DatePicker fx:id="dpPneus" maxWidth="Infinity" styleClass="form-date-picker" />
                              </children>
                           </VBox>
                           <VBox styleClass="form-field-group" GridPane.columnIndex="1" GridPane.rowIndex="1">
                              <children>
                                 <Label text="KM aux pneus" styleClass="form-label" />
                                 <TextField fx:id="txtKmPneus" text="0" styleClass="form-text-field" />
                              </children>
                           </VBox>
                        </children>
                        <rowConstraints>
                           <RowConstraints />
                           <RowConstraints />
                        </rowConstraints>
                     </GridPane>
                  </children>
               </VBox>

               <!-- ACTIONS -->
               <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="form-actions">
                  <children>
                     <Button text="Annuler" onAction="#onCancel" styleClass="btn-cancel" prefWidth="120" />
                     <Button fx:id="btnSave" text="Enregistrer l'Ambulance" onAction="#onSave" styleClass="btn-save" prefWidth="220" />
                  </children>
                  <padding>
                     <Insets top="10" />
                  </padding>
               </HBox>

            </children>
         </VBox>
      </content>
   </ScrollPane>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../css/styleMateriel.css"
      fx:controller="pro.revive.controllers.ControllersMateriel.AmbulanceDetailsController"
      spacing="0" prefWidth="900" prefHeight="700" style="-fx-background-color: #0f172a; -fx-background-radius: 12;">

   <!-- HEADER -->
   <VBox spacing="6" style="-fx-background-color: linear-gradient(to right, #8b5cf6, #6366f1); -fx-background-radius: 12 12 0 0; -fx-padding: 20 24 20 24;">
      <HBox alignment="CENTER_LEFT" spacing="12">
         <Label fx:id="lblNumero" text="AMB-XXX-TN" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
         <Label fx:id="lblEtatBadge" text="Disponible" styleClass="badge-success" 
                style="-fx-background-color: rgba(34,197,94,0.2); -fx-text-fill: #22c55e; -fx-padding: 4 12; 
                       -fx-background-radius: 12; -fx-font-size: 11px; -fx-font-weight: bold;" />
      </HBox>
      <Label fx:id="lblMarqueModele" text="Mercedes-Benz Sprinter 316 CDI" 
             style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px;" />
   </VBox>

   <!-- CONTENT -->
   <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
      <VBox spacing="20" style="-fx-padding: 24;">

         <!-- STATS CARDS -->
         <HBox spacing="16">
            <VBox spacing="8" styleClass="stat-card" HBox.hgrow="ALWAYS" 
                  style="-fx-background-color: #1e293b; -fx-padding: 16; -fx-background-radius: 8;">
               <Label text="📏  KM TOTAL" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;" />
               <Label fx:id="lblKmTotal" text="0 km" style="-fx-text-fill: #38bdf8; -fx-font-size: 24px; -fx-font-weight: bold;" />
            </VBox>
            <VBox spacing="8" styleClass="stat-card" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #1e293b; -fx-padding: 16; -fx-background-radius: 8;">
               <Label text="🛣  TRAJETS" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;" />
               <Label fx:id="lblNbTrajets" text="0" style="-fx-text-fill: #34d399; -fx-font-size: 24px; -fx-font-weight: bold;" />
            </VBox>
            <VBox spacing="8" styleClass="stat-card" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #1e293b; -fx-padding: 16; -fx-background-radius: 8;">
               <Label text="⚠️  ALERTES" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;" />
               <Label fx:id="lblNbAlertes" text="0" style="-fx-text-fill: #fbbf24; -fx-font-size: 24px; -fx-font-weight: bold;" />
            </VBox>
            <VBox spacing="8" styleClass="stat-card" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #1e293b; -fx-padding: 16; -fx-background-radius: 8;">
               <Label text="📅  ANNÉE" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;" />
               <Label fx:id="lblAnnee" text="2023" style="-fx-text-fill: #e2e8f0; -fx-font-size: 24px; -fx-font-weight: bold;" />
            </VBox>
         </HBox>

         <Separator style="-fx-background-color: #334155;" />

         <!-- ALERTES MAINTENANCE -->
         <VBox spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="12">
               <Label text="🔧  ALERTES DE MAINTENANCE IA" style="-fx-text-fill: #e2e8f0; -fx-font-size: 14px; -fx-font-weight: bold;" />
               <Region HBox.hgrow="ALWAYS" />
               <Button text="🔄  Analyser" onAction="#onAnalyserMaintenance" 
                       style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 8 16; 
                              -fx-background-radius: 6; -fx-font-size: 11px; -fx-cursor: hand;" />
            </HBox>

            <VBox fx:id="boxAlertes" spacing="8">
               <!-- Alertes dynamiques -->
            </VBox>

            <Label fx:id="lblNoAlertes" text="✅  Aucune alerte de maintenance. Véhicule en bon état." 
                   style="-fx-text-fill: #22c55e; -fx-font-size: 12px; -fx-padding: 12; 
                          -fx-background-color: rgba(34,197,94,0.1); -fx-background-radius: 6;" 
                   visible="false" managed="false" />
         </VBox>

         <Separator style="-fx-background-color: #334155;" />

         <!-- HISTORIQUE TRAJETS -->
         <VBox spacing="12">
            <Label text="🛣  HISTORIQUE DES TRAJETS" style="-fx-text-fill: #e2e8f0; -fx-font-size: 14px; -fx-font-weight: bold;" />
            
            <TableView fx:id="tableTrajets" prefHeight="250" 
                       style="-fx-background-color: #1e293b; -fx-background-radius: 8;">
               <columns>
                  <TableColumn fx:id="colDate" text="DATE" prefWidth="140" />
                  <TableColumn fx:id="colDepart" text="DÉPART" prefWidth="200" />
                  <TableColumn fx:id="colUrgence" text="URGENCE" prefWidth="200" />
                  <TableColumn fx:id="colDistance" text="DISTANCE" prefWidth="100" />
                  <TableColumn fx:id="colDuree" text="DURÉE" prefWidth="100" />
                  <TableColumn fx:id="colStatut" text="STATUT" prefWidth="100" />
               </columns>
            </TableView>
         </VBox>

         <Separator style="-fx-background-color: #334155;" />

         <!-- MAINTENANCE HISTORY -->
         <VBox spacing="12">
            <Label text="📋  HISTORIQUE MAINTENANCE" style="-fx-text-fill: #e2e8f0; -fx-font-size: 14px; -fx-font-weight: bold;" />
            
            <HBox spacing="16">
               <VBox spacing="6" HBox.hgrow="ALWAYS" 
                     style="-fx-background-color: #1e293b; -fx-padding: 14; -fx-background-radius: 6;">
                  <Label text="🛢  DERNIÈRE VIDANGE" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;" />
                  <Label fx:id="lblDateVidange" text="Non renseignée" style="-fx-text-fill: #e2e8f0; -fx-font-size: 13px;" />
                  <Label fx:id="lblKmVidange" text="0 km" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
               </VBox>
               <VBox spacing="6" HBox.hgrow="ALWAYS"
                     style="-fx-background-color: #1e293b; -fx-padding: 14; -fx-background-radius: 6;">
                  <Label text="🛞  DERNIERS PNEUS" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;" />
                  <Label fx:id="lblDatePneus" text="Non renseignée" style="-fx-text-fill: #e2e8f0; -fx-font-size: 13px;" />
                  <Label fx:id="lblKmPneus" text="0 km" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" />
               </VBox>
            </HBox>
         </VBox>

         <!-- BUTTONS -->
         <HBox spacing="12" style="-fx-padding: 12 0 0 0;">
            <Button text="✏️  Modifier" onAction="#onModifier" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; 
                           -fx-font-size: 13px; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button text="🗑  Supprimer" onAction="#onSupprimer" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; 
                           -fx-font-size: 13px; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;" />
            <Button text="❌  Fermer" onAction="#onFermer" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold; 
                           -fx-font-size: 13px; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;" />
         </HBox>

      </VBox>
   </ScrollPane>

</VBox>
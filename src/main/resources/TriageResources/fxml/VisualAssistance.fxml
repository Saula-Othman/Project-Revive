<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0"
            stylesheets="@../css/styleTriage.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pro.revive.controllers.TriageController.VisualAssistanceController"
            style="-fx-background-color: #EEF4FB;">

   <!-- ── SIDEBAR ── -->
   <left>
      <VBox styleClass="sidebar" BorderPane.alignment="CENTER">
         <VBox styleClass="logo-wrap">
            <ImageView fitWidth="170.0" preserveRatio="true" pickOnBounds="true">
               <image><Image url="@../images/logo.png" /></image>
            </ImageView>
            <Label styleClass="logo-sub" text="Systeme de Gestion des Urgences" />
         </VBox>
         <Label styleClass="nav-section" text="MENU" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="🏠  Tableau de Bord" onAction="#goDashboard" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="📋  Triages" onAction="#goTriageList" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="➕  Nouveau Triage" onAction="#goTriageAdd" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="🏥  Salles d'Attente" onAction="#goSalleList" />
         <Button mnemonicParsing="false" styleClass="nav-item, active" text="📷  Assistance Visuelle" onAction="#goVisualAssistance" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="◎  Surveillance" onAction="#goSurveillance" />
         <Region VBox.vgrow="ALWAYS" />
         <VBox styleClass="sidebar-card">
            <Label styleClass="sc-title" text="Assistance Visuelle" />
            <Label styleClass="sc-alert" text="Analyse IA en temps réel" />
            <Button mnemonicParsing="false" styleClass="sc-btn" text="Deconnexion" onAction="#deconnexion" />
         </VBox>
      </VBox>
   </left>

   <!-- ── MAIN ── -->
   <center>
      <VBox styleClass="main" BorderPane.alignment="CENTER">

         <!-- Topbar -->
         <HBox styleClass="topbar">
            <VBox spacing="2">
               <Label styleClass="page-title" text="Assistance Visuelle" />
               <Label styleClass="page-sub" text="Analyse IA du patient en temps réel" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox styleClass="user-chip">
               <VBox alignment="CENTER_RIGHT" styleClass="user-info">
                  <Label fx:id="lblUserName" styleClass="user-name" text="..." />
                  <Label styleClass="user-role" text="Infirmier Triage" />
               </VBox>
               <Label styleClass="user-av" text="U" />
            </HBox>
         </HBox>
         <Region styleClass="topbar-stripe" />

         <!-- Main content -->
         <ScrollPane fitToWidth="true" styleClass="scroll" VBox.vgrow="ALWAYS">
            <content>
               <HBox spacing="16" style="-fx-padding: 20px;">

                  <!-- ── LEFT: Camera feed ── -->
                  <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14px; -fx-padding: 16px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);">

                     <!-- Card header -->
                     <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="📷" style="-fx-font-size: 18px;" />
                        <Label text="Flux Caméra" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblStatus"
                               text="● Caméra inactive"
                               style="-fx-font-size: 12px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;" />
                     </HBox>

                     <!-- Camera view -->
                     <StackPane style="-fx-background-color: #0F172A; -fx-background-radius: 10px; -fx-min-height: 420px; -fx-pref-height: 420px;">
                        <ImageView fx:id="cameraView"
                                   fitWidth="680" fitHeight="420"
                                   preserveRatio="true"
                                   style="-fx-background-radius: 10px;" />
                        <Label fx:id="lblNoCamera"
                               text="Caméra non démarrée"
                               style="-fx-text-fill: #475569; -fx-font-size: 14px;" />
                     </StackPane>

                     <!-- Toggle button -->
                     <Button fx:id="btnToggle"
                             text="▶  Démarrer l'analyse"
                             onAction="#toggleCamera"
                             maxWidth="Infinity"
                             style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12px 20px; -fx-background-radius: 10px; -fx-cursor: hand;" />

                     <!-- Mute button -->
                     <Button fx:id="btnMute"
                             text="🔊  Son activé"
                             onAction="#toggleMute"
                             maxWidth="Infinity"
                             style="-fx-background-color: #475569; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-background-radius: 10px; -fx-cursor: hand;" />

                  </VBox>

                  <!-- ── RIGHT: Commentary panel ── -->
                  <VBox spacing="12" prefWidth="360" minWidth="300"
                        style="-fx-background-color: #FFFFFF; -fx-background-radius: 14px; -fx-padding: 16px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);">

                     <!-- Panel header -->
                     <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="🧠" style="-fx-font-size: 18px;" />
                        <Label text="Analyse IA" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblLive"
                               text="EN DIRECT"
                               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-background-color: #DCFCE7; -fx-text-fill: #16A34A; -fx-padding: 2px 8px; -fx-background-radius: 20px;" />
                     </HBox>

                     <Region style="-fx-background-color: #E2E8F0; -fx-pref-height: 1px; -fx-min-height: 1px;" />

                     <!-- Focus info badge -->
                     <HBox spacing="6" alignment="CENTER_LEFT"
                           style="-fx-background-color: #EFF6FF; -fx-padding: 8px 12px; -fx-background-radius: 8px;">
                        <Label text="🎯" style="-fx-font-size: 13px;" />
                        <Label text="Analyse : Haut du corps uniquement"
                               style="-fx-font-size: 11px; -fx-text-fill: #3B82F6; -fx-font-weight: bold;" />
                     </HBox>

                     <!-- Commentary box -->
                     <VBox VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 10px; -fx-padding: 14px; -fx-min-height: 300px;">
                        <Label fx:id="lblCommentary"
                               text="Appuyez sur 'Démarrer' pour activer l'analyse en temps réel."
                               wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #334155; -fx-line-spacing: 4px;" />
                     </VBox>

                     <!-- Disclaimer -->
                     <Label text="⚠ Résultats indicatifs uniquement. Toujours vérifier cliniquement."
                            wrapText="true"
                            style="-fx-font-size: 10px; -fx-text-fill: #94A3B8; -fx-font-style: italic;" />
                  </VBox>

               </HBox>
            </content>
         </ScrollPane>

      </VBox>
   </center>

</BorderPane>

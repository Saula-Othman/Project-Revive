<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0"
            stylesheets="@../css/styleTriage.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pro.revive.controllers.TriageController.DashboardController">

   <!-- ── SIDEBAR ── -->
   <left>
      <VBox styleClass="sidebar" BorderPane.alignment="CENTER">
         <VBox styleClass="logo-wrap">
            <ImageView fitWidth="170.0" preserveRatio="true" pickOnBounds="true">
               <image><Image url="@../images/logo.png" /></image>
            </ImageView>
            <Label styleClass="logo-sub" text="Systeme de Gestion des Urgences" />
         </VBox>
         <Label styleClass="nav-section" text="MENU" />
         <Button mnemonicParsing="false" styleClass="nav-item, active" text="🏠  Tableau de Bord" onAction="#goDashboard" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="📋  Triages" onAction="#goTriageList" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="➕  Nouveau Triage" onAction="#goTriageAdd" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="🏥  Salles d'Attente" onAction="#goSalleList" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="📷  Assistance Visuelle" onAction="#goVisualAssistance" />
         <Button mnemonicParsing="false" styleClass="nav-item" text="&#9673;  Surveillance" onAction="#goSurveillance" />
         <Region VBox.vgrow="ALWAYS" />
         <VBox styleClass="sidebar-card">
            <Label styleClass="sc-title" text="ALERTES ACTIVES" />
            <Label fx:id="alertCount" styleClass="sc-alert" text="..." />
            <Button mnemonicParsing="false" styleClass="sc-btn" text="Deconnexion" onAction="#deconnexion" />
         </VBox>
      </VBox>
   </left>

   <!-- ── MAIN ── -->
   <center>
      <VBox styleClass="main" BorderPane.alignment="CENTER">

         <!-- Topbar -->
         <!-- Topbar -->
         <HBox styleClass="topbar">
            <VBox spacing="2">
               <Label styleClass="page-title" text="Tableau de Bord" />
               <Label fx:id="lblDate" styleClass="page-sub" text="..." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox styleClass="user-chip">
               <VBox alignment="CENTER_RIGHT" styleClass="user-info">
                  <Label fx:id="lblUserName" styleClass="user-name" text="..." />
                  <Label styleClass="user-role" text="Infirmier Triage" />
               </VBox>
               <Label styleClass="user-av" text="U" />
            </HBox>
         </HBox>
         <Region styleClass="topbar-stripe" />

         <!-- Alert bar -->
         <HBox fx:id="alertBar" styleClass="alert-bar" visible="false" managed="false">
            <Label style="-fx-font-size: 16px; -fx-text-fill: #EF4444;" text="⚠" />
            <Label fx:id="alertMsg" styleClass="alert-txt" text="" HBox.hgrow="ALWAYS" />
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #EF4444; -fx-font-size: 14px; -fx-cursor: hand; -fx-border-width: 0;" text="✕" onAction="#closeAlert" />
         </HBox>

         <!-- Scrollable content area -->
         <ScrollPane fitToWidth="true" styleClass="scroll" VBox.vgrow="ALWAYS">
            <content>
               <VBox spacing="0">

         <!-- Stat cards -->
         <HBox styleClass="stats-row" spacing="16.0">
            <VBox styleClass="stat-card, blue" HBox.hgrow="ALWAYS">
               <Label styleClass="stat-lbl" text="Total Actifs" />
               <Label fx:id="statTotal" styleClass="stat-val, blue" text="0" />
               <Label styleClass="stat-hint" text="patients en cours" />
            </VBox>
            <VBox styleClass="stat-card, red" HBox.hgrow="ALWAYS">
               <Label styleClass="stat-lbl" text="Niveau 1 Critique" />
               <Label fx:id="statCritical" styleClass="stat-val, red" text="0" />
               <Label styleClass="stat-hint" text="cas urgents" />
            </VBox>
            <VBox styleClass="stat-card, orange" HBox.hgrow="ALWAYS">
               <Label styleClass="stat-lbl" text="En Attente" />
               <Label fx:id="statWaiting" styleClass="stat-val, orange" text="0" />
               <Label styleClass="stat-hint" text="sans salle assignee" />
            </VBox>
            <VBox styleClass="stat-card, green" HBox.hgrow="ALWAYS">
               <Label styleClass="stat-lbl" text="Salles Disponibles" />
               <Label fx:id="statSalles" styleClass="stat-val, green" text="0" />
               <Label styleClass="stat-hint" text="salles libres" />
            </VBox>
         </HBox>

         <!-- ── Surveillance row ── -->
         <HBox spacing="16.0" style="-fx-padding: 16px 20px 0px 20px;">

            <!-- Threat Level card -->
            <VBox fx:id="dashThreatCard" spacing="6.0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14px;
                         -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.10),14,0,0,3);
                         -fx-padding: 14px 18px;">
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <Label style="-fx-font-size: 18px;" text="🦠" />
                  <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0B4EA2;" text="Niveau de Menace Épidémique" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblDashSaison"
                         style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-padding: 2px 8px;
                                -fx-background-color: #F1F5F9; -fx-background-radius: 6px;" text="..." />
               </HBox>
               <HBox alignment="CENTER_LEFT" spacing="14.0" style="-fx-padding: 4px 0 0 0;">
                  <Label fx:id="lblDashThreatIcon"
                         style="-fx-font-size: 36px;" text="●" />
                  <VBox spacing="3.0">
                     <Label fx:id="lblDashThreatLevel"
                            style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Chargement..." />
                     <Label fx:id="lblDashThreatDesc"
                            style="-fx-font-size: 11px; -fx-text-fill: #64748B;" wrapText="true" text="" />
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" text="Voir →" onAction="#goSurveillance"
                          style="-fx-background-color: #EFF6FF; -fx-text-fill: #0B4EA2;
                                 -fx-font-size: 11px; -fx-font-weight: bold;
                                 -fx-background-radius: 8; -fx-padding: 5 12; -fx-cursor: hand;
                                 -fx-border-width: 0;" />
               </HBox>
            </VBox>

            <!-- WHO Alerts mini-feed card -->
            <VBox spacing="6.0" prefWidth="340.0"
                  style="-fx-background-color: white; -fx-background-radius: 14px;
                         -fx-effect: dropshadow(gaussian,rgba(11,78,162,0.10),14,0,0,3);
                         -fx-padding: 14px 18px;">
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <Label style="-fx-font-size: 18px;" text="🌐" />
                  <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0B4EA2;" text="Alertes OMS Récentes" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" text="Tout voir →" onAction="#goSurveillance"
                          style="-fx-background-color: #EFF6FF; -fx-text-fill: #0B4EA2;
                                 -fx-font-size: 11px; -fx-font-weight: bold;
                                 -fx-background-radius: 8; -fx-padding: 5 12; -fx-cursor: hand;
                                 -fx-border-width: 0;" />
               </HBox>
               <VBox fx:id="whoMiniBox" spacing="6.0" style="-fx-padding: 4px 0 0 0;">
                  <Label style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-style: italic;" text="Chargement des alertes OMS..." />
               </VBox>
            </VBox>

         </HBox>

         <!-- Content row -->
         <HBox styleClass="content-row" spacing="20.0" style="-fx-padding: 16px 28px 24px 28px; -fx-min-height: 420px;">
            <VBox styleClass="patients-panel" HBox.hgrow="ALWAYS" minHeight="400.0">
               <HBox styleClass="panel-hdr">
                  <Label styleClass="section-title" text="👥  Patients en Cours" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="patientCount" styleClass="panel-cnt" text="0 patients" />
               </HBox>
               <VBox fx:id="patientList" spacing="10.0" style="-fx-padding: 12px;" />
            </VBox>

            <VBox styleClass="rooms-panel" prefWidth="260.0" minHeight="400.0">
               <HBox styleClass="panel-hdr">
                  <Label styleClass="section-title" text="🏥  Salles" />
               </HBox>
               <VBox fx:id="salleList" spacing="10.0" style="-fx-padding: 12px;" />
            </VBox>
         </HBox>

               </VBox>
            </content>
         </ScrollPane>

      </VBox>
   </center>
</BorderPane>

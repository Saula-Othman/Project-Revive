<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="pro.revive.controllers.ControllersLabo.ModifierResultatController"
            prefWidth="660" prefHeight="580"
            stylesheets="@css/labo.css">

    <!-- ── TOPBAR ── -->
    <top>
        <HBox styleClass="topbar" spacing="14" alignment="CENTER_LEFT">
            <StackPane>
                <Region prefWidth="42" prefHeight="42"
                        style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 12;"/>
                <Label text="✏" style="-fx-font-size: 22px;"/>
            </StackPane>
            <VBox spacing="2">
                <Label styleClass="page-title" text="Modifier un Résultat"/>
                <Label styleClass="page-sub" text="Mise à jour du compte rendu médical"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox styleClass="user-chip">
                <Label text="🏥" style="-fx-font-size: 13px;"/>
                <Label text="Labo &amp; Imagerie"
                       style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ── FORMULAIRE ── -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll"
                    style="-fx-background-color: #EEF4FB; -fx-background: #EEF4FB;">
            <StackPane style="-fx-padding: 28 32; -fx-background-color: #EEF4FB;">
                <VBox spacing="16" maxWidth="560" styleClass="card">

                    <!-- En-tête carte -->
                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <StackPane>
                            <Region prefWidth="46" prefHeight="46"
                                    style="-fx-background-color: rgba(11,78,162,0.09); -fx-background-radius: 14;"/>
                            <Label text="✏" style="-fx-font-size: 22px;"/>
                        </StackPane>
                        <VBox spacing="3">
                            <Label text="Modifier le Résultat" styleClass="card-title" style="-fx-font-size: 19px;"/>
                            <Label text="Modifiez les informations ci-dessous" styleClass="field-hint"/>
                        </VBox>
                    </HBox>

                    <Region prefHeight="1"
                            style="-fx-background-color: linear-gradient(to right, #DBEAFE, #CCFBF1);"/>

                    <!-- Patient (lecture seule) -->
                    <VBox spacing="6">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="Patient" styleClass="field-label"/>
                            <Label text="(non modifiable)"
                                   style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;
                                          -fx-background-color: #F1F5F9; -fx-padding: 2 8; -fx-background-radius: 6;"/>
                        </HBox>
                        <HBox styleClass="info-item">
                            <Label fx:id="lblIdDemandeVal"
                                   style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        </HBox>
                    </VBox>

                    <!-- Compte rendu -->
                    <VBox spacing="6">
                        <Label text="Compte rendu *" styleClass="field-label"/>
                        <Label text="Doit être une description textuelle (pas uniquement des chiffres)"
                               styleClass="field-hint"/>
                        <TextArea fx:id="taCompteRendu"
                                  promptText="Modifier le compte rendu médical…"
                                  prefRowCount="5" wrapText="true"
                                  styleClass="text-area"/>
                        <Label fx:id="lblErrCompteRendu" styleClass="error-label"/>
                    </VBox>

                    <!-- Fichier joint -->
                    <VBox spacing="6">
                        <Label text="Fichier joint" styleClass="field-label"/>
                        <TextField fx:id="tfFichierJoint"
                                   promptText="Chemin du fichier ou URL"
                                   styleClass="text-field"/>
                    </VBox>

                    <Region prefHeight="1"
                            style="-fx-background-color: linear-gradient(to right, #DBEAFE, #CCFBF1);"/>

                    <!-- Boutons -->
                    <HBox spacing="14">
                        <VBox alignment="CENTER" spacing="4">
                            <Button onAction="#handleModifier" text="✏️"
                                    styleClass="btn, btn-primary"
                                    style="-fx-font-size: 22px; -fx-background-radius: 16;
                                           -fx-min-width: 58; -fx-min-height: 58;"
                                    onMouseEntered="#onBtnHoverEnter" onMouseExited="#onBtnHoverExit"/>
                            <Label text="Enregistrer" styleClass="stat-hint"
                                   style="-fx-text-fill: #22C55E; -fx-font-weight: bold;"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="lblMessage" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>

                </VBox>
            </StackPane>
        </ScrollPane>
    </center>

    <!-- ── FOOTER ── -->
    <bottom>
        <HBox alignment="CENTER" spacing="16" styleClass="footer">
            <Label text="REVIVE" styleClass="footer-label"
                   style="-fx-text-fill: rgba(255,255,255,0.80); -fx-font-weight: bold;"/>
            <Label text="•" styleClass="footer-label"/>
            <Label text="Laboratoire &amp; Imagerie — Urgences" styleClass="footer-label"/>
            <Label text="•" styleClass="footer-label"/>
            <Label text="© 2025" styleClass="footer-label"/>
        </HBox>
    </bottom>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="pro.revive.controllers.ControllersLabo.AnalyserResultatController"
            prefWidth="700" prefHeight="580"
            stylesheets="@css/labo.css">

    <!-- ── TOPBAR ── -->
    <top>
        <HBox styleClass="topbar" spacing="14" alignment="CENTER_LEFT">
            <StackPane>
                <Region prefWidth="46" prefHeight="46"
                        style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 14;"/>
                <Label text="🤖" style="-fx-font-size: 26px;"/>
            </StackPane>
            <VBox spacing="2">
                <Label styleClass="page-title" text="Assistant Médical IA"/>
                <Label styleClass="page-sub" text="Analyse intelligente des résultats d'examens"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox styleClass="user-chip">
                <Label text="🏥" style="-fx-font-size: 13px;"/>
                <Label text="Labo &amp; Imagerie"
                       style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ── CONTENU ── -->
    <center>
        <VBox spacing="0" style="-fx-background-color: #EEF4FB;">

            <!-- Barre info résultat -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: white;
                         -fx-padding: 10 22;
                         -fx-border-color: #DDD6FE; -fx-border-width: 0 0 1 0;">
                <StackPane>
                    <Region prefWidth="28" prefHeight="28"
                            style="-fx-background-color: rgba(124,58,237,0.10); -fx-background-radius: 8;"/>
                    <Label text="📋" style="-fx-font-size: 13px;"/>
                </StackPane>
                <Label fx:id="lblInfoResultat" text="Aucun résultat sélectionné"
                       style="-fx-text-fill: #5B21B6; -fx-font-size: 11px; -fx-font-weight: bold;"
                       HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblModeIA" text="⏳  Vérification…"
                       style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
            </HBox>

            <!-- Panneau clé API -->
            <VBox fx:id="panneauCleAPI" spacing="6"
                  style="-fx-background-color: #FFFBEB;
                         -fx-padding: 10 22;
                         -fx-border-color: #FDE68A; -fx-border-width: 0 0 1 0;">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="🔑" style="-fx-font-size: 13px;"/>
                    <Label text="Clé API Gemini (pour l'IA avancée) :"
                           style="-fx-text-fill: #92400E; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label text="Obtenez-la gratuitement sur aistudio.google.com"
                           style="-fx-text-fill: #B45309; -fx-font-size: 10px;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="tfCleAPI"
                               promptText="AIza… (votre clé API Google Gemini)"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-radius: 8; -fx-border-radius: 8;
                                      -fx-border-color: #FDE68A; -fx-padding: 6 10; -fx-font-size: 11px;"/>
                    <Button text="💾  Sauvegarder" onAction="#handleSauvegarderCle"
                            style="-fx-background-color: #7C3AED; -fx-text-fill: white;
                                   -fx-font-size: 11px; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Zone chat -->
            <ScrollPane fx:id="scrollChat" fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #F8FAFF; -fx-background: #F8FAFF;"
                        prefHeight="300">
                <VBox fx:id="containerMessages" spacing="10" style="-fx-padding: 18;"/>
            </ScrollPane>

            <!-- Zone saisie -->
            <VBox spacing="0"
                  style="-fx-background-color: white;
                         -fx-border-color: #DDD6FE; -fx-border-width: 1 0 0 0;
                         -fx-padding: 12 18;">
                <HBox spacing="12" alignment="CENTER">
                    <TextArea fx:id="taQuestion"
                              promptText="Posez votre question… (Entrée pour envoyer, Shift+Entrée pour nouvelle ligne)"
                              prefRowCount="2" wrapText="true"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-radius: 12; -fx-border-radius: 12;
                                     -fx-border-color: #DDD6FE; -fx-padding: 9 12; -fx-font-size: 13px;"/>
                    <VBox spacing="8" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="3">
                            <Button onAction="#handleEnvoyer" text="📤"
                                    style="-fx-background-color: linear-gradient(to bottom, #7C3AED, #6D28D9);
                                           -fx-text-fill: white; -fx-font-size: 20px; -fx-background-radius: 14;
                                           -fx-min-width: 52; -fx-min-height: 52; -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian,rgba(124,58,237,0.45),10,0,0,4);"
                                    onMouseEntered="#onBtnHoverEnter" onMouseExited="#onBtnHoverExit"/>
                            <Label text="Envoyer"
                                   style="-fx-text-fill: #7C3AED; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="3">
                            <Button onAction="#handleEffacer" text="🧹"
                                    style="-fx-background-color: #F3F4F6; -fx-text-fill: #6B7280;
                                           -fx-font-size: 18px; -fx-background-radius: 12;
                                           -fx-min-width: 44; -fx-min-height: 44; -fx-cursor: hand;
                                           -fx-border-color: #E5E7EB; -fx-border-radius: 12;"
                                    onMouseEntered="#onBtnHoverEnter" onMouseExited="#onBtnHoverExit"/>
                            <Label text="Effacer"
                                   style="-fx-text-fill: #6B7280; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        </VBox>
                    </VBox>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 6 0 0 0;">
                    <Label text="💡" style="-fx-font-size: 11px;"/>
                    <Label text="L'assistant mémorise la conversation pour des réponses contextuelles."
                           styleClass="field-hint" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblStatutEnvoi" text="⏳  Analyse en cours…" visible="false"
                           style="-fx-text-fill: #7C3AED; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

        </VBox>
    </center>

    <!-- ── FOOTER ── -->
    <bottom>
        <HBox alignment="CENTER" spacing="16" styleClass="footer">
            <Label text="REVIVE" styleClass="footer-label"
                   style="-fx-text-fill: rgba(255,255,255,0.80); -fx-font-weight: bold;"/>
            <Label text="•" styleClass="footer-label"/>
            <Label text="Assistant Médical IA — Labo &amp; Imagerie" styleClass="footer-label"/>
            <Label text="•" styleClass="footer-label"/>
            <Label text="© 2025" styleClass="footer-label"/>
        </HBox>
    </bottom>

</BorderPane>
